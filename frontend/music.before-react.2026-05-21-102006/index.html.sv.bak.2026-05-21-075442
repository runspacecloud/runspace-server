<!DOCTYPE html>
<html lang="sv">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>RunSpace / Music</title>
  <style>
    :root{
      --bg:#070d18;
      --bg2:#0d1525;
      --panel:#0d1627;
      --panel2:#121d31;
      --panel3:#17243b;
      --border:rgba(255,255,255,.08);
      --border2:rgba(255,255,255,.12);
      --text:#f3f6fb;
      --muted:#95a4bf;
      --muted2:#6f809b;
      --accent:#63a8ff;
      --accent2:#5865f2;
      --good:#22c55e;
      --danger:#ef4444;
      --shadow:0 18px 60px rgba(0,0,0,.35);
      --radius:18px;
    }

    *{box-sizing:border-box;margin:0;padding:0}
    html,body{height:100%}
    body{
      font-family:system-ui,-apple-system,Segoe UI,Roboto,sans-serif;
      color:var(--text);
      background:
        radial-gradient(circle at 20% 0%, rgba(90,120,255,.08), transparent 28%),
        radial-gradient(circle at 100% 10%, rgba(0,180,255,.06), transparent 22%),
        linear-gradient(180deg,#08111d 0%, #07101b 100%);
      overflow:hidden;
    }

    .app{
      height:100%;
      display:grid;
      grid-template-rows:78px 1fr 112px;
    }

    /* Topbar */
    .topbar{
      display:grid;
      grid-template-columns: 270px 1fr 110px;
      align-items:center;
      gap:18px;
      padding:18px 22px;
      border-bottom:1px solid var(--border);
      background:rgba(8,15,26,.72);
      backdrop-filter: blur(10px);
    }

    .brand{
      display:flex;
      align-items:center;
      gap:14px;
      min-width:0;
    }

    .brand-icon{
      width:32px;height:32px;border-radius:999px;
      background:linear-gradient(135deg,#4f7cff,#6270ff);
      position:relative;
      box-shadow:0 0 0 6px rgba(88,101,242,.12);
      flex:0 0 auto;
    }

    .brand-icon::after{
      content:"";
      position:absolute;
      inset:9px;
      border-radius:999px;
      background:#0e1730;
    }

    .brand-text{
      font-size:18px;
      font-weight:800;
      white-space:nowrap;
    }

    .brand-text span{
      color:var(--muted);
      font-weight:600;
      margin-left:8px;
    }

    .top-search{
      position:relative;
    }

    .top-search input{
      width:100%;
      height:48px;
      border-radius:15px;
      border:1px solid var(--border);
      background:rgba(21,32,53,.88);
      color:var(--text);
      padding:0 18px 0 48px;
      outline:none;
      font-size:15px;
      box-shadow:inset 0 1px 0 rgba(255,255,255,.02);
    }

    .top-search input::placeholder{color:#7f90ad}

    .top-search svg{
      position:absolute;
      left:16px;
      top:50%;
      transform:translateY(-50%);
      width:18px;height:18px;
      opacity:.75;
    }

    .top-actions{
      display:flex;
      justify-content:flex-end;
      align-items:center;
      gap:12px;
    }

    .avatar-btn,.notif-btn{
      width:44px;height:44px;border-radius:14px;
      border:1px solid var(--border);
      background:rgba(21,32,53,.88);
      display:grid;place-items:center;
      color:var(--text);
    }

    /* Main layout */
    .content{
      min-height:0;
      display:grid;
      grid-template-columns: 286px 1fr;
    }

    .sidebar{
      border-right:1px solid var(--border);
      background:linear-gradient(180deg, rgba(8,16,29,.92), rgba(10,20,37,.92));
      padding:22px 20px;
      overflow:auto;
    }

    .sidebar-header{
      display:flex;
      align-items:center;
      justify-content:space-between;
      margin-bottom:18px;
    }

    .sidebar-title{
      font-size:17px;
      font-weight:800;
      text-transform:uppercase;
      letter-spacing:.04em;
    }

    .mini-create{
      border:1px solid var(--border2);
      background:rgba(255,255,255,.04);
      color:var(--text);
      border-radius:11px;
      padding:9px 14px;
      font-weight:700;
      cursor:pointer;
    }

    .playlist-list{
      list-style:none;
      display:flex;
      flex-direction:column;
      gap:8px;
      margin-bottom:22px;
    }

    .playlist-list .nav__item{
      display:flex;
      align-items:center;
      justify-content:space-between;
      min-height:50px;
      padding:0 14px;
      border-radius:14px;
      color:var(--text);
      cursor:pointer;
      border:1px solid transparent;
      background:transparent;
      transition:.15s ease;
      font-size:15px;
    }

    .playlist-list .nav__item:hover{
      background:rgba(255,255,255,.04);
      border-color:rgba(255,255,255,.05);
    }

    .playlist-list .nav__item.active{
      background:rgba(122,162,255,.13);
      border-color:rgba(122,162,255,.18);
      box-shadow: inset 0 1px 0 rgba(255,255,255,.02);
    }

    .playlist-list .nav__item-soft{
      color:var(--muted);
      min-height:42px;
      background:transparent !important;
      border-color:transparent !important;
      cursor:default;
      padding-left:14px;
    }

    .sidebar-bottom{
      margin-top:18px;
      padding-top:14px;
    }

    .big-create{
      width:100%;
      height:52px;
      border-radius:14px;
      border:1px solid rgba(121,188,255,.24);
      background:linear-gradient(180deg, #6cc0ff, #61aef5);
      color:#08111d;
      font-size:15px;
      font-weight:800;
      cursor:pointer;
      box-shadow:0 12px 30px rgba(74,140,255,.18);
    }

    /* Main panel */
    .main{
      min-width:0;
      padding:18px 20px 22px;
      overflow:auto;
    }

    .main-shell{
      min-height:100%;
      border-radius:22px;
      border:1px solid var(--border);
      background:
        radial-gradient(circle at top right, rgba(120,170,255,.10), transparent 26%),
        radial-gradient(circle at 20% 0%, rgba(0,180,255,.05), transparent 30%),
        linear-gradient(180deg, rgba(16,24,41,.98), rgba(9,17,30,.98));
      box-shadow:var(--shadow);
      padding:24px 26px 22px;
    }

    .welcome{
      font-size:28px;
      font-weight:900;
      margin-bottom:18px;
      letter-spacing:-.02em;
    }

    .cards-layout{
      display:grid;
      grid-template-columns: 1fr 1fr;
      gap:18px;
      margin-bottom:18px;
    }

    .section-card{
      background:rgba(255,255,255,.025);
      border:1px solid rgba(255,255,255,.05);
      border-radius:18px;
      padding:16px;
    }

    .section-head{
      display:flex;
      align-items:center;
      justify-content:space-between;
      margin-bottom:12px;
    }

    .section-title{
      font-size:16px;
      font-weight:800;
    }

    .section-arrows{
      display:flex;gap:8px;color:var(--muted)
    }

    .arrow-btn{
      width:26px;height:26px;border-radius:999px;border:1px solid var(--border);
      display:grid;place-items:center;
      background:rgba(255,255,255,.03);
      font-size:12px;
    }

    .card-row{
      display:flex;
      gap:12px;
      overflow-x:auto;
      padding-bottom:2px;
      min-height:154px;
    }

    .music-card{
      width:146px;
      min-width:146px;
      border:1px solid rgba(255,255,255,.06);
      background:rgba(255,255,255,.03);
      border-radius:16px;
      padding:10px;
      color:var(--text);
      text-align:left;
      cursor:pointer;
    }

    .music-card-art{
      width:100%;
      height:92px;
      border-radius:12px;
      background:linear-gradient(135deg, rgba(96,140,255,.22), rgba(255,255,255,.04));
      background-size:cover;
      background-position:center;
      display:grid;
      place-items:center;
      margin-bottom:9px;
      overflow:hidden;
    }

    .music-card-title{
      font-size:13px;
      font-weight:700;
      line-height:1.2;
      height:32px;
      overflow:hidden;
    }

    .music-card-sub{
      margin-top:4px;
      color:var(--muted);
      font-size:12px;
    }

    .music-empty-line{
      width:100%;
      border:1px dashed rgba(255,255,255,.08);
      border-radius:16px;
      padding:26px 20px;
      color:var(--muted);
      display:flex;
      align-items:center;
      background:rgba(255,255,255,.015);
    }

    /* Playlist panel */
    .playlist-panel{
      margin-top:8px;
      border-radius:18px;
      border:1px solid rgba(255,255,255,.05);
      background:rgba(255,255,255,.022);
      overflow:hidden;
    }

    .playlist-panel-head{
      display:grid;
      grid-template-columns:1fr auto;
      align-items:center;
      gap:12px;
      padding:16px 18px 12px;
      border-bottom:1px solid rgba(255,255,255,.05);
    }

    .playlist-head-left{
      display:flex;
      align-items:center;
      gap:12px;
      flex-wrap:wrap;
      min-width:0;
    }

    .playlist-name{
      font-size:18px;
      font-weight:900;
    }

    .playlist-meta{
      color:var(--muted);
      font-size:14px;
    }

    .playlist-menu{
      width:42px;height:42px;border-radius:14px;
      border:1px solid var(--border);
      background:rgba(255,255,255,.03);
      color:var(--text);
      font-size:20px;
      cursor:pointer;
    }

    .table-wrap{
      overflow:auto;
      max-height:420px;
    }

    table{
      width:100%;
      border-collapse:collapse;
    }

    thead th{
      color:var(--muted2);
      font-size:12px;
      text-transform:uppercase;
      font-weight:800;
      letter-spacing:.04em;
      padding:14px 16px;
      border-bottom:1px solid rgba(255,255,255,.05);
      text-align:left;
    }

    tbody td{
      padding:14px 16px;
      border-bottom:1px solid rgba(255,255,255,.05);
      vertical-align:middle;
    }

    tbody tr{
      transition:.12s ease;
    }

    tbody tr:hover{
      background:rgba(255,255,255,.03);
    }

    .source{
      width:26px;height:26px;border-radius:999px;
      display:inline-grid;place-items:center;
      font-size:12px;font-weight:900;
    }

    .source-youtube{
      color:#fff;
      background:rgba(239,68,68,.20);
    }

    .source-spotify{
      color:#86efac;
      background:rgba(34,197,94,.18);
    }

    .source-local{
      color:#93c5fd;
      background:rgba(59,130,246,.16);
    }

    .track-title-cell{
      display:flex;
      align-items:center;
      gap:12px;
      min-width:0;
    }

    .track-title-cell img,.mini-art{
      width:40px;height:40px;border-radius:10px;
      flex:0 0 auto;
      object-fit:cover;
      display:grid;place-items:center;
      background:rgba(255,255,255,.05);
    }

    .track-main-title{
      font-weight:700;
      white-space:nowrap;
      overflow:hidden;
      text-overflow:ellipsis;
      max-width:520px;
    }

    .track-sub-title{
      margin-top:3px;
      color:var(--muted);
      font-size:12px;
    }

    .music-table-empty{
      text-align:center;
      color:var(--muted);
      padding:28px !important;
      background:rgba(255,255,255,.015);
    }

    .row-menu-btn{
      border:0;
      background:transparent;
      color:var(--muted);
      font-size:18px;
      cursor:pointer;
    }

    .is-current-track{
      background:rgba(99,168,255,.09);
    }

    /* Player */
    .player{
      display:grid;
      grid-template-columns: 360px 1fr 270px;
      align-items:center;
      gap:22px;
      padding:16px 24px;
      border-top:1px solid var(--border);
      background:
        linear-gradient(180deg, rgba(12,20,34,.98), rgba(11,18,31,.98));
      backdrop-filter: blur(10px);
    }

    .player-left{
      display:flex;
      align-items:center;
      gap:14px;
      min-width:0;
    }

    #now-thumb{
      width:62px;
      height:62px;
      border-radius:14px;
      background:rgba(255,255,255,.05);
      overflow:hidden;
      display:grid;
      place-items:center;
      flex:0 0 auto;
    }

    .now-meta{
      min-width:0;
    }

    #now-title{
      font-size:15px;
      font-weight:800;
      white-space:nowrap;
      overflow:hidden;
      text-overflow:ellipsis;
    }

    #now-artist{
      font-size:13px;
      color:var(--muted);
      margin-top:4px;
      white-space:nowrap;
      overflow:hidden;
      text-overflow:ellipsis;
    }

    .player-center{
      display:flex;
      flex-direction:column;
      align-items:center;
      gap:10px;
      min-width:0;
    }

    .control-row{
      display:flex;
      align-items:center;
      gap:12px;
    }

    .tiny-btn,.play-btn{
      border:1px solid var(--border);
      background:rgba(255,255,255,.035);
      color:var(--text);
      cursor:pointer;
      display:grid;
      place-items:center;
    }

    .tiny-btn{
      width:42px;height:42px;border-radius:999px;
    }

    .play-btn{
      width:58px;height:58px;border-radius:999px;
      background:linear-gradient(180deg, #677cff, #5d6eff);
      border-color:rgba(120,140,255,.35);
      font-size:22px;
      font-weight:900;
      box-shadow:0 12px 30px rgba(92,110,255,.22);
    }

    .progress-wrap{
      width:100%;
      display:grid;
      grid-template-columns: 52px 1fr 52px;
      align-items:center;
      gap:12px;
    }

    #time-current,#time-total{
      font-size:13px;
      color:var(--text);
      font-variant-numeric:tabular-nums;
      text-align:center;
    }

    #progress-bar{
      position:relative;
      height:7px;
      border-radius:999px;
      background:rgba(255,255,255,.09);
      overflow:hidden;
      cursor:pointer;
    }

    #progress-fill{
      position:absolute;
      top:0;left:0;height:100%;
      width:0%;
      border-radius:999px;
      background:linear-gradient(90deg, #63a8ff, #7ab2ff);
    }

    .player-right{
      display:flex;
      justify-content:flex-end;
      align-items:center;
      gap:12px;
    }

    .speaker{
      font-size:21px;
      color:var(--text);
    }

    #volume-slider{
      width:160px;
      accent-color:#86baff;
    }

    .nav-count{color:var(--muted);font-size:12px}
    .nav-name{white-space:nowrap;overflow:hidden;text-overflow:ellipsis}

    ::-webkit-scrollbar{width:10px;height:10px}
    ::-webkit-scrollbar-track{background:rgba(255,255,255,.02)}
    ::-webkit-scrollbar-thumb{
      background:rgba(108,146,255,.35);
      border-radius:999px;
      border:2px solid transparent;
      background-clip:padding-box;
    }

    @media (max-width: 1200px){
      .cards-layout{grid-template-columns:1fr}
      .player{grid-template-columns:1fr; gap:14px; height:auto}
      .topbar{grid-template-columns:220px 1fr 70px}
      .content{grid-template-columns:250px 1fr}
    }

    @media (max-width: 920px){
      body{overflow:auto}
      .app{grid-template-rows:78px auto auto}
      .content{grid-template-columns:1fr}
      .sidebar{border-right:0;border-bottom:1px solid var(--border)}
      .main{padding:12px}
      .topbar{grid-template-columns:1fr}
      .player{position:static}
    }
  </style>
</head>
<body>
  <div class="app">
    <header class="topbar">
      <div class="brand">
        <div class="brand-icon"></div>
        <div class="brand-text">RunSpace <span>/ Music</span></div>
      </div>

      <div class="top-search">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="7"></circle>
          <path d="M20 20l-3.5-3.5"></path>
        </svg>
        <input id="global-search" type="text" placeholder="Sök efter musik (YouTube, Spotify, etc.)" />
      </div>

      <div class="top-actions">
        <button class="avatar-btn" type="button">👤</button>
      </div>
    </header>

    <div class="content">
      <aside class="sidebar">
        <div class="sidebar-header">
          <div class="sidebar-title">Bibliotek</div>
          <button class="mini-create" id="btn-create-playlist-top" type="button">Skapa</button>
        </div>

        <ul class="playlist-list" id="playlist-list"></ul>

        <div class="sidebar-bottom">
          <button class="big-create" id="btn-create-playlist" type="button">Skapa</button>
        </div>
      </aside>

      <main class="main">
        <div class="main-shell">
          <h1 class="welcome" id="greeting">Välkommen tillbaka</h1>

          <div class="cards-layout">
            <section class="section-card">
              <div class="section-head">
                <div class="section-title">Nyligen spelat</div>
                <div class="section-arrows">
                  <div class="arrow-btn">‹</div>
                  <div class="arrow-btn">›</div>
                </div>
              </div>
              <div class="card-row" id="recent-row"></div>
            </section>

            <section class="section-card">
              <div class="section-head">
                <div class="section-title">Trendar just nu</div>
                <div class="section-arrows">
                  <div class="arrow-btn">‹</div>
                  <div class="arrow-btn">›</div>
                </div>
              </div>
              <div class="card-row" id="trending-row"></div>
            </section>
          </div>

          <section class="playlist-panel">
            <div class="playlist-panel-head">
              <div class="playlist-head-left">
                <div class="playlist-name">Huvudspellista: <span id="playlist-count">0 spår</span></div>
                <div class="playlist-meta" id="playlist-meta-text"></div>
              </div>
              <button class="playlist-menu" id="playlist-menu" type="button">⋯</button>
            </div>

            <div class="table-wrap">
              <table class="table" id="track-table">
                <thead>
                  <tr>
                    <th style="width:70px;"></th>
                    <th>Titel</th>
                    <th>Artist</th>
                    <th style="width:90px;text-align:right;">Tid</th>
                    <th style="width:60px;"></th>
                  </tr>
                </thead>
                <tbody id="track-tbody"></tbody>
              </table>
            </div>
          </section>
        </div>
      </main>
    </div>

    <footer class="player" id="player-bar">
      <div class="player-left">
        <div id="now-thumb"></div>
        <div class="now-meta">
          <div id="now-title">No track selected</div>
          <div id="now-artist">—</div>
        </div>
      </div>

      <div class="player-center">
        <div class="control-row">
          <button class="tiny-btn" id="btn-prev" type="button">⏮</button>
          <button class="play-btn" id="btn-play" type="button">▶</button>
          <button class="tiny-btn" id="btn-next" type="button">⏭</button>
        </div>

        <div class="progress-wrap">
          <div id="time-current">0:00</div>
          <div id="progress-bar">
            <div id="progress-fill"></div>
          </div>
          <div id="time-total">0:00</div>
        </div>
      </div>

      <div class="player-right">
        <div class="speaker">🔊</div>
        <input id="volume-slider" type="range" min="0" max="100" value="80" />
      </div>
    </footer>
  </div>

  <script>
    // gör övre "Skapa"-knappen till samma funktion som den nedre
    document.addEventListener('DOMContentLoaded', function () {
      var topBtn = document.getElementById('btn-create-playlist-top');
      var mainBtn = document.getElementById('btn-create-playlist');
      if (topBtn && mainBtn) {
        topBtn.addEventListener('click', function () {
          mainBtn.click();
        });
      }
    });
  </script>

  <script src="script.js?v=7" defer></script>
</body>
</html>
