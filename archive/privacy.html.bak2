<!DOCTYPE html>
<html lang="en">
<head>

<script>
// ── Clear any stale data on page load ──
sessionStorage.removeItem('_cached_user');
// ── Device Token (persistent per browser) ──
(function() {
  let tok = localStorage.getItem('rs_device_token');
  if (!tok) {
    tok = 'web-' + Array.from(crypto.getRandomValues(new Uint8Array(16))).map(b=>b.toString(16).padStart(2,'0')).join('');
    localStorage.setItem('rs_device_token', tok);
  }
  window._rsDeviceToken = tok;

  const _origFetch = window.fetch;
  window.fetch = function(url, opts={}) {
    opts.headers = opts.headers || {};
    if (typeof opts.headers === 'object' && !Array.isArray(opts.headers)) {
      opts.headers['X-Device-Token'] = tok;
      opts.headers['X-Device-Name'] = navigator.userAgent.slice(0, 50);
    }
    return _origFetch(url, opts);
  };
})();
</script>

<meta charset="UTF-8">
<link rel="icon" href="/favicon.ico">
<link rel="icon" type="image/png" sizes="1024x1024" href="/assets/runspace_icon_1024.png">
<link rel="apple-touch-icon" sizes="1024x1024" href="/assets/runspace_icon_1024.png">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Privacy · RunSpace</title>
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700;800&amp;family=DM+Sans:wght@400;500;600;700;800&amp;display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#07070d;--surface:#07070d;--surface-2:#07070d;--surface-3:#0d1321;
  --border:rgba(255,255,255,.06);--border-hover:rgba(255,255,255,.14);
  --text:#eaf0ff;--muted:#5e7594;--dim:#8facc7;
  --accent:#3b7dff;--accent-hover:#2b6be6;--accent-glow:rgba(59,125,255,.18);--accent-subtle:rgba(59,125,255,.07);
  --danger:#ef4444;--success:#10b981;--warn:#f59e0b;--purple:#a78bfa;
  --radius:10px;--radius-lg:16px;
  --font-body:'DM Sans',system-ui,sans-serif;
  --font-mono:'JetBrains Mono',monospace;
}
html{background:#07070d !important}
html,body{background:transparent;min-height:100vh;color:var(--text);font-family:var(--font-body);font-size:14px;line-height:1.5}
a{color:inherit;text-decoration:none}button,input{font:inherit;color:inherit}

@keyframes fadeUp{from{opacity:0;transform:translateY(14px)}to{opacity:1;transform:translateY(0)}}
@keyframes breathe{0%,100%{opacity:.12}50%{opacity:.22}}
@keyframes dotPulse{0%,100%{transform:scale(1);opacity:1}50%{transform:scale(1.4);opacity:.6}}
.fade-up{animation:fadeUp .5s ease both}
.d1{animation-delay:.04s}.d2{animation-delay:.1s}.d3{animation-delay:.16s}.d4{animation-delay:.22s}

/* ── Starfield background ── */
.rs-star-canvas{position:fixed;inset:0;overflow:hidden;pointer-events:none;z-index:0}
.rs-star-dot{position:absolute;border-radius:50%;animation:rsFall linear infinite}
@keyframes rsFall{from{transform:translateY(-10px);opacity:0}5%{opacity:1}95%{opacity:1}to{transform:translateY(100vh);opacity:0}}

/* ── Shell ── */
.shell{position:relative;z-index:1;display:grid;grid-template-columns:230px 1fr;min-height:100vh}

/* ── Sidebar ── */
.side{position:sticky;top:0;height:100vh;overflow-y:auto;background:transparent;border-right:1px solid var(--border);padding:20px 12px;display:flex;flex-direction:column;gap:2px;scrollbar-width:thin;scrollbar-color:var(--surface-3) transparent;z-index:1}
.logo{display:flex;align-items:center;gap:10px;padding:6px 8px 22px}
.logo-icon{width:36px;height:36px;border-radius:10px;background:linear-gradient(135deg,#3b7dff,#6c5ce7);display:flex;align-items:center;justify-content:center;font-weight:800;font-size:14px;color:#fff;flex-shrink:0;box-shadow:0 4px 16px rgba(59,125,255,.25)}
.logo span{font-size:17px;font-weight:800;letter-spacing:-.4px}
.nav-label{font-size:10px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:1px;padding:18px 10px 6px}
.nav-item{display:flex;align-items:center;gap:10px;padding:9px 12px;border-radius:8px;color:var(--muted);font-weight:600;font-size:13px;cursor:pointer;border:none;background:none;width:100%;text-align:left;transition:all .15s ease;position:relative}
.nav-item:hover{background:rgba(255,255,255,.05);color:var(--text);transform:translateX(5px)}
.nav-item.active{background:rgba(59,125,255,.12);color:var(--accent);font-weight:700}
.nav-item.active::before{content:'';position:absolute;left:0;top:50%;transform:translateY(-50%);width:3px;height:20px;border-radius:0 3px 3px 0;background:var(--accent);box-shadow:0 0 8px var(--accent-glow)}
.nav-icon{width:16px;height:16px;flex-shrink:0;stroke:currentColor;stroke-width:1.75;fill:none;stroke-linecap:round;stroke-linejoin:round}
.side-footer{margin-top:auto;padding:16px 10px;font-size:11px;color:var(--muted);font-family:var(--font-mono)}

/* ── Main ── */
.main{position:relative;z-index:1;display:flex;flex-direction:column;min-width:0;background:transparent}
.top{position:sticky;top:0;z-index:20;background:rgba(7,11,20,.88);backdrop-filter:blur(16px);border-bottom:1px solid var(--border);padding:10px 28px;display:flex;align-items:center;gap:14px}
.top-title{font-weight:700;font-size:13px;color:var(--dim);display:flex;align-items:center;gap:10px}
.top-title-sep{color:var(--muted);font-family:var(--font-mono)}
.top-right{margin-left:auto;display:flex;align-items:center;gap:6px}
.lang-btn{padding:5px 8px;border-radius:6px;border:1px solid transparent;background:none;font-size:11px;font-weight:700;cursor:pointer;color:var(--muted);transition:all .15s;font-family:var(--font-mono)}
.lang-btn:hover,.lang-btn.active{background:rgba(255,255,255,.04);color:var(--dim);border-color:var(--border)}
.menu-toggle{display:none;padding:8px 12px;border-radius:8px;border:1px solid var(--border);background:none;color:var(--dim);cursor:pointer;font-size:13px;font-weight:600;transition:all .15s ease}
.menu-toggle:hover{background:rgba(255,255,255,.04);color:var(--text);border-color:var(--border-hover)}

/* ── Sidebar close button (mobile only) ── */
.side-close{display:none;position:absolute;top:16px;right:14px;width:36px;height:36px;border-radius:10px;border:1px solid var(--border-hover);background:var(--surface-3);color:var(--text);cursor:pointer;font-size:22px;line-height:1;align-items:center;justify-content:center;transition:all .15s ease;z-index:2;font-family:var(--font-mono);font-weight:400}
.side-close:hover{background:rgba(239,68,68,.1);color:#fca5a5;border-color:rgba(239,68,68,.25)}

/* ── Mobile overlay ── */
.menu-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.4);z-index:99;opacity:0;transition:opacity .2s ease;cursor:pointer}
body.menu-open .menu-overlay{display:block;opacity:1}

/* ── Page ── */
.page{max-width:880px;width:100%;margin:0 auto;padding:28px 28px 60px;display:flex;flex-direction:column}

/* ── Hero ── */
.privacy-hero{position:relative;padding:36px 32px;background:linear-gradient(145deg,var(--surface) 0%,var(--surface-2) 60%,rgba(59,125,255,.04) 100%);border:1px solid var(--border);border-radius:var(--radius-lg);overflow:hidden;margin-bottom:20px}
.privacy-hero::before{content:'';position:absolute;top:-60px;right:-40px;width:260px;height:260px;border-radius:50%;background:radial-gradient(circle,rgba(59,125,255,.14) 0%,transparent 70%);pointer-events:none;animation:breathe 5s ease infinite}
.privacy-hero-eyebrow{font-family:var(--font-mono);font-size:11px;font-weight:700;color:var(--accent);text-transform:uppercase;letter-spacing:1.2px;margin-bottom:10px;display:flex;align-items:center;gap:8px;position:relative;z-index:1}
.privacy-hero-eyebrow-dot{width:7px;height:7px;border-radius:50%;background:var(--accent);box-shadow:0 0 8px var(--accent-glow);animation:dotPulse 2.5s ease infinite}
.privacy-hero h1{font-size:30px;font-weight:800;letter-spacing:-.6px;line-height:1.15;margin-bottom:10px;position:relative;z-index:1}
.privacy-hero-meta{font-family:var(--font-mono);font-size:11px;color:var(--muted);position:relative;z-index:1}
.privacy-hero-lede{margin-top:18px;font-size:14px;color:var(--dim);line-height:1.65;max-width:64ch;position:relative;z-index:1}

/* ── TOC ── */
.toc{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-lg);padding:22px;margin-bottom:22px}
.toc-title{font-family:var(--font-mono);font-size:10px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:1px;margin-bottom:14px}
.toc-grid{display:grid;grid-template-columns:1fr 1fr;gap:4px}
.toc-link{display:flex;align-items:center;gap:10px;padding:8px 10px;border-radius:7px;color:var(--dim);font-size:13px;font-weight:500;transition:all .15s ease}
.toc-link:hover{background:rgba(255,255,255,.04);color:var(--text);transform:translateX(3px)}
.toc-num{font-family:var(--font-mono);font-size:10px;color:var(--muted);font-weight:700;min-width:18px}

/* ── Sections ── */
.section{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-lg);padding:26px 28px;margin-bottom:12px;transition:border-color .2s}
.section:hover{border-color:var(--border-hover)}
.section-head{display:flex;align-items:center;gap:12px;margin-bottom:14px}
.section-num{font-family:var(--font-mono);font-size:11px;font-weight:700;color:var(--accent);background:var(--accent-subtle);border:1px solid rgba(59,125,255,.15);padding:4px 8px;border-radius:6px;letter-spacing:.5px;flex-shrink:0}
.section h2{font-size:17px;font-weight:800;letter-spacing:-.2px}
.section p{color:var(--dim);font-size:13.5px;line-height:1.7;margin-bottom:10px}
.section p:last-child{margin-bottom:0}
.section h3{font-size:13px;font-weight:700;color:var(--text);margin:16px 0 8px;font-family:var(--font-mono);text-transform:uppercase;letter-spacing:.8px}
.section ul{list-style:none;padding:0;margin:0 0 8px}
.section ul li{position:relative;padding:7px 0 7px 22px;color:var(--dim);font-size:13.5px;line-height:1.65}
.section ul li::before{content:'';position:absolute;left:6px;top:15px;width:5px;height:5px;border-radius:50%;background:var(--accent);box-shadow:0 0 6px var(--accent-glow)}
.section ul li strong{color:var(--text);font-weight:700}
.section code{font-family:var(--font-mono);font-size:12px;background:var(--surface-3);border:1px solid var(--border);padding:2px 7px;border-radius:5px;color:var(--dim)}
.section a{color:var(--accent);font-weight:600;transition:color .15s}
.section a:hover{color:var(--accent-hover);text-decoration:underline}

/* ── Callout ── */
.callout{margin:16px 0;padding:16px 18px;background:linear-gradient(135deg,rgba(59,125,255,.06),rgba(59,125,255,.02));border:1px solid rgba(59,125,255,.15);border-left:3px solid var(--accent);border-radius:10px;font-size:13px;color:var(--dim);line-height:1.65;position:relative}
.callout::after{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--accent),transparent);opacity:.4}
.callout strong{color:var(--text);font-weight:700}

/* ── Contact card ── */
.contact-card{background:linear-gradient(145deg,var(--surface) 0%,rgba(59,125,255,.04) 100%);border:1px solid var(--border);border-radius:var(--radius-lg);padding:26px 28px;margin-top:20px;display:flex;align-items:center;gap:18px;position:relative;overflow:hidden}
.contact-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent 10%,var(--accent) 50%,transparent 90%);opacity:.25}
.contact-icon{width:48px;height:48px;border-radius:12px;background:var(--accent-subtle);border:1px solid rgba(59,125,255,.15);display:flex;align-items:center;justify-content:center;flex-shrink:0}
.contact-icon svg{width:22px;height:22px;stroke:var(--accent);stroke-width:1.75;fill:none;stroke-linecap:round;stroke-linejoin:round}
.contact-text{flex:1;min-width:0}
.contact-label{font-size:11px;color:var(--muted);font-family:var(--font-mono);text-transform:uppercase;letter-spacing:.8px;margin-bottom:4px}
.contact-email{font-size:16px;font-weight:700;color:var(--text);font-family:var(--font-mono)}

/* ── Footer ── */
.page-footer{margin-top:30px;padding-top:20px;border-top:1px solid var(--border);font-size:11px;color:var(--muted);font-family:var(--font-mono)}
.page-footer-support{padding-bottom:20px;margin-bottom:18px;border-bottom:1px solid var(--border)}
.page-footer-support-head{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.8px;color:var(--dim);margin-bottom:10px}
.page-footer-tz{font-weight:400;letter-spacing:0;color:var(--muted);text-transform:none}
.page-footer-hours{list-style:none;padding:0;margin:0 0 12px 0;display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:6px 24px;max-width:380px;font-variant-numeric:tabular-nums}
.page-footer-hours li{display:flex;justify-content:space-between;gap:12px}
.page-footer-hours li span:first-child{color:var(--muted)}
.page-footer-hours li span:last-child{color:var(--text);opacity:.85}
.page-footer-support-note{font-size:11px;color:var(--muted);line-height:1.5}
.page-footer-support-note a{color:var(--text);opacity:.85;text-decoration:underline;text-decoration-color:rgba(255,255,255,.2);text-underline-offset:2px;transition:text-decoration-color .15s}
.page-footer-support-note a:hover{text-decoration-color:rgba(255,255,255,.6)}
.page-footer-bottom{display:flex;align-items:center;justify-content:space-between}
.page-footer-tagline{display:flex;align-items:center;gap:10px}
.page-footer-dot{width:4px;height:4px;border-radius:50%;background:var(--muted)}
@media(max-width:600px){.page-footer-hours{grid-template-columns:1fr;max-width:none}.page-footer-bottom{flex-direction:column;align-items:flex-start;gap:8px}}

@media(max-width:900px){
  .shell{grid-template-columns:1fr}
  .side{position:fixed;left:0;top:0;bottom:0;width:260px;z-index:100;transform:translateX(-100%);transition:transform .25s ease;background:#0a0a14;border-right:1px solid var(--border-hover);box-shadow:8px 0 32px rgba(0,0,0,.5);padding-top:60px}
  body.menu-open .side{transform:translateX(0)}
  .side-close{display:flex}
  .menu-toggle{display:block}
  .page{padding:20px 16px 40px}
  .privacy-hero{padding:26px 22px}
  .privacy-hero h1{font-size:24px}
  .section{padding:22px 20px}
  .toc-grid{grid-template-columns:1fr}
  .contact-card{flex-direction:column;text-align:center;padding:22px}
}
</style>
</head>

<body>

<!-- Starfield -->
<div class="rs-star-canvas" id="rsStarCanvas" aria-hidden="true"></div>

<!-- Mobile menu overlay -->
<div class="menu-overlay" onclick="document.body.classList.remove('menu-open')" aria-hidden="true"></div>

<div class="shell">

  <!-- Sidebar -->
  <aside class="side">
    <button class="side-close" onclick="document.body.classList.remove('menu-open')" aria-label="Close menu">×</button>
    <a href="/" class="logo">
      <div class="logo-icon">R</div>
      <span>RunSpace</span>
    </a>

    <div class="nav-label">Platform</div>
    <a class="nav-item" href="/">
      <svg class="nav-icon" viewBox="0 0 24 24"><path d="M3 12l9-9 9 9"/><path d="M5 10v10a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V10"/></svg>
      Home
    </a>
    <a class="nav-item" href="/about">
      <svg class="nav-icon" viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"/><line x1="12" y1="11" x2="12" y2="16"/><circle cx="12" cy="8" r="0.5" fill="currentColor"/></svg>
      About
    </a>
    <a class="nav-item" href="/download">
      <svg class="nav-icon" viewBox="0 0 24 24"><path d="M12 3v11"/><polyline points="7 10 12 15 17 10"/><path d="M4 18v2a1 1 0 0 0 1 1h14a1 1 0 0 0 1-1v-2"/></svg>
      Download
    </a>
    <a class="nav-item" href="/news">
      <svg class="nav-icon" viewBox="0 0 24 24"><path d="M4 5h13a1 1 0 0 1 1 1v13a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1V5z"/><path d="M18 8h2a1 1 0 0 1 1 1v9a2 2 0 0 1-2 2"/><line x1="7" y1="9" x2="15" y2="9"/><line x1="7" y1="13" x2="15" y2="13"/><line x1="7" y1="17" x2="11" y2="17"/></svg>
      News
    </a>

    <div class="nav-label">Legal</div>
    <a class="nav-item" href="/terms">
      <svg class="nav-icon" viewBox="0 0 24 24"><path d="M14 3H7a1 1 0 0 0-1 1v16a1 1 0 0 0 1 1h10a1 1 0 0 0 1-1V7z"/><polyline points="14 3 14 7 18 7"/><line x1="9" y1="12" x2="15" y2="12"/><line x1="9" y1="16" x2="13" y2="16"/></svg>
      Terms
    </a>
    <a class="nav-item active" href="/privacy" aria-current="page">
      <svg class="nav-icon" viewBox="0 0 24 24"><path d="M12 3l8 3v6c0 4.5-3.5 8.5-8 9-4.5-.5-8-4.5-8-9V6l8-3z"/><polyline points="9 12 11 14 15 10"/></svg>
      Privacy
    </a>

    <div class="side-footer">v1.0 · GDPR-compliant</div>
  </aside>

  <!-- Main -->
  <main class="main">

    <header class="top">
      <button class="menu-toggle" onclick="document.body.classList.toggle('menu-open')" aria-label="Toggle menu">☰</button>
      <div class="top-title">
        <span>Legal</span>
        <span class="top-title-sep">/</span>
        <span style="color:var(--text)">Privacy Policy</span>
      </div>
      <div class="top-right">
        <button class="lang-btn active">EN</button>
        <button class="lang-btn">SV</button>
      </div>
    </header>

    <div class="page">

      <!-- Hero -->
      <section class="privacy-hero fade-up">
        <div class="privacy-hero-eyebrow">
          <span class="privacy-hero-eyebrow-dot"></span>
          Privacy · Freedom · Control
        </div>
        <h1>Privacy Policy</h1>
        <div class="privacy-hero-meta">Last updated 2026-04-22 · GDPR-aligned</div>
        <p class="privacy-hero-lede">
          RunSpace is built on the premise that your conversations belong to you. This document describes what we collect, what we can and cannot see, and the rights you have under the GDPR. Written in plain English — no dark patterns, no hidden fine print.
        </p>
      </section>

      <!-- TOC -->
      <section class="toc fade-up d1">
        <div class="toc-title">Contents</div>
        <div class="toc-grid">
          <a class="toc-link" href="#controller"><span class="toc-num">01</span>Who we are</a>
          <a class="toc-link" href="#principles"><span class="toc-num">02</span>Principles</a>
          <a class="toc-link" href="#data"><span class="toc-num">03</span>Data we collect</a>
          <a class="toc-link" href="#e2e"><span class="toc-num">04</span>End-to-end encryption</a>
          <a class="toc-link" href="#devices"><span class="toc-num">05</span>Devices &amp; trust</a>
          <a class="toc-link" href="#cookies"><span class="toc-num">06</span>Cookies &amp; sessions</a>
          <a class="toc-link" href="#retention"><span class="toc-num">07</span>Retention &amp; deletion</a>
          <a class="toc-link" href="#legal-basis"><span class="toc-num">08</span>Legal basis</a>
          <a class="toc-link" href="#sharing"><span class="toc-num">09</span>Sharing &amp; processors</a>
          <a class="toc-link" href="#rights"><span class="toc-num">10</span>Your rights</a>
          <a class="toc-link" href="#security"><span class="toc-num">11</span>Security</a>
          <a class="toc-link" href="#minors"><span class="toc-num">12</span>Minors</a>
        </div>
      </section>

      <!-- 01 -->
      <section class="section fade-up d2" id="controller">
        <div class="section-head">
          <span class="section-num">01</span>
          <h2>Who we are</h2>
        </div>
        <p>RunSpace is a self-hosted, privately operated chat platform reachable at <code>runspace.cloud</code>. The service is operated by an individual, not a company. For the purposes of the EU General Data Protection Regulation, that individual is the <strong>data controller</strong>.</p>
        <p>Contact: <code>support@runspace.cloud</code></p>
      </section>

      <!-- 02 -->
      <section class="section fade-up d2" id="principles">
        <div class="section-head">
          <span class="section-num">02</span>
          <h2>Principles</h2>
        </div>
        <p>Three things guide every decision about how RunSpace handles data:</p>
        <ul>
          <li><strong>Collect as little as possible.</strong> If we don't need it to run the service, we don't ask for it.</li>
          <li><strong>See as little as possible.</strong> Message content is end-to-end encrypted — the server stores ciphertext, not plaintext.</li>
          <li><strong>Keep it only as long as necessary.</strong> Deletion means deletion, not "hidden but retained".</li>
        </ul>
      </section>

      <!-- 03 -->
      <section class="section fade-up d3" id="data">
        <div class="section-head">
          <span class="section-num">03</span>
          <h2>Data we collect</h2>
        </div>

        <h3>Account data</h3>
        <ul>
          <li>Username (chosen by you, may be a pseudonym)</li>
          <li>Email address (verification codes and recovery only)</li>
          <li>A hashed password — we never store or see your plaintext password</li>
          <li>Optional profile fields: display name, avatar, nationality, language</li>
        </ul>

        <h3>Message data</h3>
        <ul>
          <li>DMs and group DMs are end-to-end encrypted. The server stores only ciphertext plus routing metadata (sender, recipient, timestamp).</li>
          <li>Public channel messages are stored readable — they're public by nature.</li>
          <li>E2E-encrypted uploads remain encrypted at rest.</li>
        </ul>

        <h3>Technical data</h3>
        <ul>
          <li>IP address, user-agent, request timing (short-term logs for abuse prevention)</li>
          <li>Device fingerprint and trust score</li>
          <li>hCaptcha signals (sign-up and suspicious events only)</li>
        </ul>

        <h3>What we do <em>not</em> collect</h3>
        <ul>
          <li>No third-party analytics. No Google Analytics, no Facebook pixels, no ad trackers.</li>
          <li>No phone numbers, no real-name requirement, no contact-book uploads.</li>
          <li>No fine-grained location beyond country/city IP geolocation.</li>
        </ul>
      </section>

      <!-- 04 -->
      <section class="section fade-up d3" id="e2e">
        <div class="section-head">
          <span class="section-num">04</span>
          <h2>End-to-end encryption</h2>
        </div>
        <p>DMs, group DMs, and E2E-flagged uploads are encrypted on your device before they reach the server. RunSpace uses <strong>RSA-OAEP (SHA-256)</strong> for key exchange and <strong>AES-256-GCM</strong> for message content. Private keys live on your device and never leave it in plaintext.</p>
        <p>This has two consequences worth understanding:</p>
        <ul>
          <li>The server operator cannot read your encrypted messages. Law-enforcement requests for message content cannot be fulfilled — the data does not exist in readable form.</li>
          <li>If you lose access to all your devices without backing up your keys, your encrypted history is unrecoverable. This is a deliberate trade-off.</li>
        </ul>
        <div class="callout">
          <strong>Metadata is not content.</strong> End-to-end encryption protects message <em>contents</em>. The server still needs routing metadata (who sent what to whom, when) to deliver messages. If metadata protection matters, use a pseudonym and a VPN or Tor.
        </div>
      </section>

      <!-- 05 -->
      <section class="section fade-up d4" id="devices">
        <div class="section-head">
          <span class="section-num">05</span>
          <h2>Devices &amp; trust</h2>
        </div>
        <p>RunSpace uses a multi-device model similar to Signal's. When you sign in on a new device:</p>
        <ul>
          <li>The device generates its own RSA keypair locally.</li>
          <li>The server stores the device's public key and a persistent <strong>device identifier</strong> (a UUID kept on disk on your device).</li>
          <li>Each device gets a <strong>trust score</strong> based on age, verification state, and moderation history.</li>
        </ul>
        <p>Trust scores are used internally for rate-limiting, spam detection, and moderation. They are not sold, shared, or used for advertising. You can view and revoke trusted devices from your account settings.</p>
      </section>

      <!-- 06 -->
      <section class="section fade-up d4" id="cookies">
        <div class="section-head">
          <span class="section-num">06</span>
          <h2>Cookies &amp; sessions</h2>
        </div>
        <p>RunSpace uses only strictly necessary cookies and local storage:</p>
        <ul>
          <li><code>session</code> — keeps you signed in. HttpOnly, Secure, SameSite=Lax.</li>
          <li><code>rs_device_token</code> — identifies your device for E2E routing. Stored locally.</li>
          <li>Private key material — browser local storage (web) and on-disk (Qt desktop client).</li>
        </ul>
        <p>No tracking cookies. No third-party cookies. No consent banner — there's nothing to consent to beyond what's strictly necessary to operate the service.</p>
      </section>

      <!-- 07 -->
      <section class="section fade-up" id="retention">
        <div class="section-head">
          <span class="section-num">07</span>
          <h2>Retention &amp; deletion</h2>
        </div>
        <ul>
          <li><strong>Messages:</strong> retained until you or the other party deletes them, or until the account is deleted.</li>
          <li><strong>Server logs:</strong> typically 14 days, then rotated.</li>
          <li><strong>Email verification codes:</strong> minutes. Discarded after use or expiry.</li>
          <li><strong>Moderation records:</strong> retained while involved accounts remain active, plus a limited appeal window.</li>
          <li><strong>Account deletion:</strong> removes your profile, authored messages, device keys, and trust history. Some aggregate abuse-signal counters may persist in anonymised form.</li>
        </ul>
      </section>

      <!-- 08 -->
      <section class="section fade-up" id="legal-basis">
        <div class="section-head">
          <span class="section-num">08</span>
          <h2>Legal basis (GDPR)</h2>
        </div>
        <p>We rely on the following lawful bases under Article 6 GDPR:</p>
        <ul>
          <li><strong>Performance of a contract</strong> (Art. 6(1)(b)) — to provide the service you signed up for.</li>
          <li><strong>Legitimate interests</strong> (Art. 6(1)(f)) — abuse prevention, security, keeping the service running.</li>
          <li><strong>Consent</strong> (Art. 6(1)(a)) — for anything optional. Withdrawable at any time.</li>
          <li><strong>Legal obligation</strong> (Art. 6(1)(c)) — where we're compelled by law.</li>
        </ul>
      </section>

      <!-- 09 -->
      <section class="section fade-up" id="sharing">
        <div class="section-head">
          <span class="section-num">09</span>
          <h2>Sharing &amp; processors</h2>
        </div>
        <p>RunSpace does not sell or rent personal data. A small number of sub-processors handle narrow, well-defined tasks:</p>
        <ul>
          <li><strong>Hetzner</strong> (Germany) — EU-based hosting with a GDPR-compliant DPA.</li>
          <li><strong>SendGrid / Twilio</strong> — transactional email (verification codes, security notices). Receives your email and the code only.</li>
          <li><strong>hCaptcha</strong> — bot detection on sign-up and suspicious events.</li>
          <li><strong>coturn</strong> (self-hosted) — relays voice/video when direct P2P isn't possible. Sees encrypted media packets, not contents.</li>
        </ul>
        <p>Disclosure to authorities: we respond to legally valid requests under applicable law. Because message contents are end-to-end encrypted, we can't hand over what we don't have.</p>
      </section>

      <!-- 10 -->
      <section class="section fade-up" id="rights">
        <div class="section-head">
          <span class="section-num">10</span>
          <h2>Your rights</h2>
        </div>
        <p>Under the GDPR you have the right to:</p>
        <ul>
          <li><strong>Access</strong> — request a copy of the personal data we hold about you.</li>
          <li><strong>Rectification</strong> — correct inaccurate data.</li>
          <li><strong>Erasure</strong> — delete your account and associated data.</li>
          <li><strong>Restriction</strong> — ask us to pause processing in specific cases.</li>
          <li><strong>Portability</strong> — receive your data in a machine-readable format.</li>
          <li><strong>Objection</strong> — object to processing based on legitimate interests.</li>
          <li><strong>Withdraw consent</strong> — at any time, where processing is based on consent.</li>
          <li><strong>Lodge a complaint</strong> — with your local supervisory authority. In Sweden: Integritetsskyddsmyndigheten (IMY).</li>
        </ul>
        <p>Most of these can be exercised directly from account settings. For anything else, email <code>support@runspace.cloud</code> — we respond within 30 days.</p>
      </section>

      <!-- 11 -->
      <section class="section fade-up" id="security">
        <div class="section-head">
          <span class="section-num">11</span>
          <h2>Security</h2>
        </div>
        <p>We take security seriously because the platform's entire premise depends on it:</p>
        <ul>
          <li>TLS in transit (HTTPS enforced, HSTS enabled).</li>
          <li>End-to-end encryption for DMs, group DMs, and flagged uploads.</li>
          <li>Modern KDF for password hashing — no plaintext storage, ever.</li>
          <li>Device trust scoring and anomaly detection.</li>
          <li>Rate limiting, hCaptcha, and an IP threat-intelligence blocklist.</li>
          <li>Regular codebase security review.</li>
        </ul>
        <p>No system is perfectly secure. If you find a vulnerability, please report it responsibly to <code>support@runspace.cloud</code>.</p>
      </section>

      <!-- 12 -->
      <section class="section fade-up" id="minors">
        <div class="section-head">
          <span class="section-num">12</span>
          <h2>Minors</h2>
        </div>
        <p>RunSpace is not directed at children under 13, and under 16 in jurisdictions where that is the GDPR digital-consent threshold. Do not create an account if you are under the applicable age in your country. If we learn that an account belongs to a child below the threshold, we will remove it.</p>
      </section>

      <!-- Contact -->
      <section class="contact-card fade-up">
        <div class="contact-icon">
          <svg viewBox="0 0 24 24"><path d="M4 6a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6z"/><polyline points="4 7 12 13 20 7"/></svg>
        </div>
        <div class="contact-text">
          <div class="contact-label">Questions or requests</div>
          <div class="contact-email">support@runspace.cloud</div>
        </div>
      </section>

      <!-- Footer -->
      <div class="page-footer">
        <div class="page-footer-support">
          <div class="page-footer-support-head">Support Hours <span class="page-footer-tz">(CET)</span></div>
          <ul class="page-footer-hours">
            <li><span>Mon–Thu</span><span>12:00–21:00</span></li>
            <li><span>Fri</span><span>12:00–00:00</span></li>
            <li><span>Sat</span><span>14:30–00:00</span></li>
            <li><span>Sun</span><span>14:30–21:00</span></li>
          </ul>
          <div class="page-footer-support-note">
            Outside these hours: <a href="/support">open a ticket</a> and we'll respond as soon as possible.
          </div>
        </div>
        <div class="page-footer-bottom">
          <div class="page-footer-tagline">
            <span>RunSpace</span>
            <span class="page-footer-dot"></span>
            <span>Privacy · Freedom · Control</span>
          </div>
          <div>© 2026</div>
        </div>
      </div>

    </div>
  </main>
</div>

<script>
// ── Starfield ──
(function(){
  const canvas = document.getElementById('rsStarCanvas');
  if (!canvas) return;
  const count = 60;
  for (let i = 0; i < count; i++) {
    const dot = document.createElement('div');
    dot.className = 'rs-star-dot';
    const size = Math.random() * 2 + 0.5;
    const duration = Math.random() * 30 + 20;
    const delay = Math.random() * -50;
    const opacity = Math.random() * 0.5 + 0.2;
    dot.style.width = size + 'px';
    dot.style.height = size + 'px';
    dot.style.left = (Math.random() * 100) + '%';
    dot.style.background = Math.random() > 0.85 ? '#3b7dff' : '#eaf0ff';
    dot.style.opacity = opacity;
    dot.style.animationDuration = duration + 's';
    dot.style.animationDelay = delay + 's';
    dot.style.boxShadow = size > 1.5 ? '0 0 ' + (size * 2) + 'px currentColor' : 'none';
    canvas.appendChild(dot);
  }
})();

// ── Escape closes mobile menu ──
document.addEventListener('keydown', function(e){
  if (e.key === 'Escape') document.body.classList.remove('menu-open');
});

// ── Close menu when a nav link is tapped (on mobile) ──
document.querySelectorAll('.side .nav-item').forEach(function(el){
  el.addEventListener('click', function(){
    if (window.innerWidth <= 900) document.body.classList.remove('menu-open');
  });
});
</script>

</body>
</html>
