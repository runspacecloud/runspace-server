<script>
var curPanel = 'email';
var skipEmail = false;
var pendingToken = '';
var generatedKey = '';
var otpSecs = 600, otpInt = null, resendCD = 0;

var eyeOpen = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>';
var eyeClosed = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0112 20c-7 0-11-8-11-8a18.45 18.45 0 015.06-5.94M9.9 4.24A9.12 9.12 0 0112 4c7 0 11 8 11 8a18.5 18.5 0 01-2.16 3.19m-6.72-1.07a3 3 0 11-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>';

function toggleEye(iId, bId) {
  var inp = document.getElementById(iId), btn = document.getElementById(bId);
  var h = inp.type === 'password';
  inp.type = h ? 'text' : 'password';
  btn.innerHTML = h ? eyeClosed : eyeOpen;
}

function generateUUID() {
  if (crypto.randomUUID) return crypto.randomUUID();
  return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, function(c) {
    var r = Math.random() * 16 | 0, v = c == 'x' ? r : (r & 0x3 | 0x8);
    return v.toString(16);
  });
}

function clearAlerts() {
  ['al-err','al-ok','al-warn'].forEach(function(id){ document.getElementById(id).classList.remove('show'); });
}
function showErr(t,s){ clearAlerts(); document.getElementById('al-err-t').textContent=t||'Error'; document.getElementById('al-err-s').textContent=s||''; document.getElementById('al-err').classList.add('show'); }
function showOk(t,s){ clearAlerts(); document.getElementById('al-ok-t').textContent=t||'Done'; document.getElementById('al-ok-s').textContent=s||''; document.getElementById('al-ok').classList.add('show'); }
function showWarn(t,s){ clearAlerts(); document.getElementById('al-warn-t').textContent=t||'Notice'; document.getElementById('al-warn-s').textContent=s||''; document.getElementById('al-warn').classList.add('show'); }

var panelMeta = {
  email: {t:'Create account', s:'Private by default'},
  otp:   {t:'Verify your email', s:'Almost there'},
  key:   {t:'Your account key', s:'Store it safely'},
  user:  {t:'Choose a username', s:'You can change this later'},
  done:  {t:'Welcome', s:'Account ready'}
};

function showPanel(id) {
  document.querySelectorAll('.panel').forEach(function(p){ p.classList.remove('active'); });
  document.getElementById('p-'+id).classList.add('active');
  curPanel = id;
  var m = panelMeta[id];
  if (m) { document.getElementById('htitle').textContent = m.t; document.getElementById('hsub').textContent = m.s; }
}

function setBtn(id, lId, state, text) {
  var b = document.getElementById(id); b.className = 'btn'; b.disabled = false;
  if (state === 'loading') { b.disabled=true; b.innerHTML='<div class="spin"></div><span>'+text+'</span>'; }
  else if (state === 'ok') { b.disabled=true; b.classList.add('bok'); b.innerHTML='<span>done</span>'; }
  else { b.innerHTML='<span id="'+lId+'">'+text+'</span>'; }
}

function toggleSkip() {
  skipEmail = !skipEmail;
  var box = document.getElementById('skip-box');
  skipEmail ? box.classList.add('on') : box.classList.remove('on');
  var fe = document.getElementById('fe');
  fe.disabled = skipEmail;
  fe.style.opacity = skipEmail ? '0.4' : '1';
}

async function handleEmail() {
  clearAlerts();
  var email = document.getElementById('fe').value.trim();
  if (skipEmail || !email) {
    generatedKey = generateUUID();
    document.getElementById('key-display').textContent = generatedKey;
    document.getElementById('fu').value = 'user_' + generatedKey.split('-')[0];
    showPanel('key');
    return;
  }
  if (!email.includes('@')) { showErr('Invalid email', 'Enter a valid email address.'); return; }
  setBtn('ebtn','ebln','loading','Sending code...');
  try {
    var res = await fetch('/api/auth/register-email', {
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body: JSON.stringify({email: email})
    });
    var data = await res.json();
    if (data.status === 'otp_required' || data.status === 'ok') {
      pendingToken = data.pendingToken || email;
      document.getElementById('otp-em').textContent = email;
      setBtn('ebtn','ebln','normal','Continue');
      showPanel('otp');
      startOtpTimer();
      setTimeout(function(){ document.querySelector('#p-otp .dg').focus(); }, 100);
    } else {
      setBtn('ebtn','ebln','normal','Continue');
      showErr(data.message || 'Could not send code', '');
    }
  } catch(e) {
    setBtn('ebtn','ebln','normal','Continue');
    showErr('Connection error', 'Could not reach the server.');
  }
}

function startOtpTimer() {
  otpSecs=600; if(otpInt) clearInterval(otpInt); updateOtpTimer(otpSecs);
  resendCD=30; document.getElementById('resend-btn').disabled=true; document.getElementById('resend-btn').textContent='Resend in 30s';
  otpInt=setInterval(function(){
    otpSecs--; updateOtpTimer(otpSecs);
    if(resendCD>0){resendCD--;var rb=document.getElementById('resend-btn');if(resendCD>0){rb.disabled=true;rb.textContent='Resend in '+resendCD+'s';}else{rb.disabled=false;rb.textContent='Resend code';}}
    if(otpSecs<=0){clearInterval(otpInt);document.getElementById('otimer').textContent='Code expired';document.getElementById('otimer').style.color='var(--red)';}
  },1000);
}
function updateOtpTimer(s){var m=Math.floor(s/60),r=s%60;document.getElementById('otimer').textContent='Expires in '+m+':'+(r<10?'0':'')+r;}

async function handleOtpVerify() {
  var digits = Array.from(document.querySelectorAll('#p-otp .dg')).map(function(i){return i.value;}), code = digits.join('');
  if (code.length < 6) { showErr('Incomplete code','Enter all 6 digits.'); return; }
  clearAlerts(); setBtn('obtn','obln','loading','Verifying...');
  try {
    var res = await fetch('/api/auth/verify-email-otp', {
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body: JSON.stringify({pendingToken: pendingToken, code: code})
    });
    var data = await res.json();
    if (data.status === 'ok') {
      generatedKey = generateUUID();
      document.getElementById('key-display').textContent = generatedKey;
      document.getElementById('fu').value = 'user_' + generatedKey.split('-')[0];
      setBtn('obtn','obln','normal','Verify email');
      clearAlerts();
      showPanel('key');
    } else {
      setBtn('obtn','obln','normal','Verify email');
      showErr('Incorrect code', data.attemptsLeft ? data.attemptsLeft+' attempts remaining.' : 'Request a new code.');
      document.querySelectorAll('#p-otp .dg').forEach(function(d){d.classList.add('shake');setTimeout(function(){d.classList.remove('shake');d.value='';d.classList.remove('filled');},380);});
      setTimeout(function(){document.querySelector('#p-otp .dg').focus();},420);
    }
  } catch(e) {
    setBtn('obtn','obln','normal','Verify email');
    showErr('Connection error','Could not reach the server.');
  }
}

async function resendOtp() {
  if (!pendingToken) return;
  resendCD=30; document.getElementById('resend-btn').disabled=true;
  try {
    var res = await fetch('/api/auth/resend-otp',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({pendingToken:pendingToken})});
    var data = await res.json();
    if(data.status==='ok') showOk('Code resent','Check your inbox.');
    else showErr('Could not resend',data.message||'Try again.');
  } catch(e){ showErr('Connection error','Please try again.'); }
}

document.querySelectorAll('#p-otp .dg').forEach(function(inp,i,all){
  inp.addEventListener('input',function(){var v=inp.value.replace(/\D/g,'');inp.value=v.slice(-1);if(v){inp.classList.add('filled');if(i<all.length-1)all[i+1].focus();else{inp.blur();handleOtpVerify();}}else inp.classList.remove('filled');});
  inp.addEventListener('keydown',function(e){if(e.key==='Backspace'&&!inp.value&&i>0){all[i-1].value='';all[i-1].classList.remove('filled');all[i-1].focus();}});
  inp.addEventListener('paste',function(e){e.preventDefault();var t=(e.clipboardData||window.clipboardData).getData('text').replace(/\D/g,'');all.forEach(function(d,j){if(t[j]){d.value=t[j];d.classList.add('filled');}});if(t.length>=6)handleOtpVerify();else all[Math.min(t.length,5)].focus();});
});

async function handleDownload() {
  var pp = document.getElementById('fpp').value;
  if (!pp || pp.length < 6) {
    document.getElementById('mpp').className='fmsg err show';
    document.getElementById('mpp-text').textContent='Passphrase must be at least 6 characters.';
    return;
  }
  document.getElementById('mpp').classList.remove('show');
  setBtn('dlbtn','dlbln','loading','Encrypting...');
  try {
    var enc = await encryptKey(generatedKey, pp);
    var blob = new Blob([enc], {type:'application/octet-stream'});
    var a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = 'runspace.key';
    a.click();
    URL.revokeObjectURL(a.href);
    setBtn('dlbtn','dlbln','ok','Downloaded');
    showOk('Key file saved', 'Keep it safe. You will need it to log in.');
    setTimeout(function(){ showPanel('user'); clearAlerts(); }, 1800);
  } catch(e) {
    setBtn('dlbtn','dlbln','normal','Download key file');
    showErr('Encryption failed', e.message);
  }
}

function handleSkipDownload() {
  showWarn('No key file downloaded', 'You can download your key file later from settings.');
  setTimeout(function(){ showPanel('user'); clearAlerts(); }, 1200);
}

async function encryptKey(keyStr, passphrase) {
  var enc = new TextEncoder();
  var keyData = enc.encode(keyStr);
  var salt = crypto.getRandomValues(new Uint8Array(16));
  var iv = crypto.getRandomValues(new Uint8Array(12));
  var baseKey = await crypto.subtle.importKey('raw', enc.encode(passphrase), {name:'PBKDF2'}, false, ['deriveKey']);
  var aesKey = await crypto.subtle.deriveKey(
    {name:'PBKDF2', salt:salt, iterations:100000, hash:'SHA-256'},
    baseKey, {name:'AES-GCM', length:256}, false, ['encrypt']
  );
  var ciphertext = await crypto.subtle.encrypt({name:'AES-GCM', iv:iv}, aesKey, keyData);
  var magic = new Uint8Array([0x52,0x53,0x4B,0x31]);
  var result = new Uint8Array(4 + 16 + 12 + ciphertext.byteLength);
  result.set(magic, 0);
  result.set(salt, 4);
  result.set(iv, 20);
  result.set(new Uint8Array(ciphertext), 32);
  return result;
}

var usernameTimer = null, usernameValid = false;
document.getElementById('fu').addEventListener('input', function(){
  var val = this.value.trim(); usernameValid = false;
  var m = document.getElementById('mu'); m.classList.remove('show');
  clearTimeout(usernameTimer);
  if (!val) return;
  if (val.length < 3) { m.className='fmsg warn show'; document.getElementById('mu-text').textContent='At least 3 characters'; return; }
  if (!/^[a-zA-Z0-9_.\-]+$/.test(val)) { m.className='fmsg err show'; document.getElementById('mu-text').textContent='Only letters, numbers, _ . - allowed'; return; }
  document.getElementById('ucheck').style.display='block';
  usernameTimer = setTimeout(async function(){
    document.getElementById('ucheck').style.display='none';
    try {
      var res = await fetch('/api/auth/check-username?username='+encodeURIComponent(val));
      var data = await res.json();
      if (data.available) { document.getElementById('mu').className='fmsg ok show'; document.getElementById('mu-text').textContent=val+' is available'; usernameValid=true; }
      else { document.getElementById('mu').className='fmsg err show'; document.getElementById('mu-text').textContent=val+' is already taken'; }
    } catch(e){ document.getElementById('mu').className='fmsg warn show'; document.getElementById('mu-text').textContent='Could not check'; }
  }, 600);
});

async function handleUsername() {
  var username = document.getElementById('fu').value.trim();
  if (!username || username.length < 3) { showErr('Username required','Choose a username of at least 3 characters.'); return; }
  clearAlerts();
  setBtn('ubtn','ubln','loading','Creating account...');
  try {
    var res = await fetch('/api/auth/register-with-key', {
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body: JSON.stringify({
        username: username,
        accountKey: generatedKey,
        pendingToken: pendingToken,
        signals: buildSignals()
      })
    });
    var data = await res.json();
    if (data.status === 'ok') {
      if (data.deviceToken) {
        localStorage.setItem('rs_dt', data.deviceToken);
        localStorage.setItem('rs_trusted_'+data.deviceToken,'1');
      }
      setBtn('ubtn','ubln','ok','Created');
      showPanel('done');
    } else {
      setBtn('ubtn','ubln','normal','Create account');
      showErr(data.message || 'Could not create account','Try a different username.');
    }
  } catch(e) {
    setBtn('ubtn','ubln','normal','Create account');
    showErr('Connection error','Could not reach the server.');
  }
}

var SIG={mouse:0,keys:0,paste:false}, sessionStart=Date.now(), mousePos=[], firstInput=false;
document.addEventListener('mousemove',function(e){SIG.mouse++;mousePos.push([e.clientX,e.clientY]);if(mousePos.length>200)mousePos.shift();});
document.addEventListener('keydown',function(){SIG.keys++;});
document.addEventListener('paste',function(){SIG.paste=true;});
function entropy(){if(mousePos.length<10)return 0;var d=[];for(var i=1;i<mousePos.length;i++){var dx=mousePos[i][0]-mousePos[i-1][0],dy=mousePos[i][1]-mousePos[i-1][1];if(dx||dy)d.push(Math.atan2(dy,dx));}if(d.length<5)return 0;var m=d.reduce(function(a,b){return a+b;},0)/d.length,v=d.reduce(function(s,x){return s+Math.pow(x-m,2);},0)/d.length;return Math.min(1,v/2);}
function devToken(){try{var k='rs_dt',e=localStorage.getItem(k);if(e)return e;var a=new Uint8Array(24);crypto.getRandomValues(a);var t='dt_'+Array.from(a).map(function(b){return b.toString(16).padStart(2,'0');}).join('');localStorage.setItem(k,t);return t;}catch(e){return '';}}
function buildSignals(){return{mouseEventCount:SIG.mouse,keystrokeCount:SIG.keys,copyPasteDetected:SIG.paste,mouseEntropyScore:+entropy().toFixed(2),isHeadless:!!navigator.webdriver,screenResolution:screen.width+'x'+screen.height,timezone:Intl.DateTimeFormat().resolvedOptions().timeZone||'',userAgent:navigator.userAgent,sessionAgeSeconds:Math.floor((Date.now()-sessionStart)/1000),deviceToken:devToken()};}

document.addEventListener('keydown',function(e){if(e.key==='Enter'&&curPanel==='email')handleEmail();});
