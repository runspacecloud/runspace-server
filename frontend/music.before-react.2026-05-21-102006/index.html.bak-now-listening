<script>
(function runspaceMusicUpgrades() {
  function waitForApp() {
    if (
      typeof db === 'undefined' ||
      typeof tracks === 'undefined' ||
      typeof playlists === 'undefined' ||
      typeof activePlaylistId === 'undefined' ||
      !document.getElementById('playlist-tabs')
    ) {
      setTimeout(waitForApp, 100);
      return;
    }

    installUpgradeUI();
    patchPlaylistRendering();
    patchLoaderWithSorting();

    if (typeof loadActivePlaylist === 'function') {
      loadActivePlaylist().catch(() => {});
    }
  }

  function playlistStorePut(playlist) {
    return new Promise((res, rej) => {
      const tx = db.transaction('playlists', 'readwrite');
      tx.objectStore('playlists').put(playlist);
      tx.oncomplete = () => res();
      tx.onerror = () => rej(tx.error);
    });
  }

  function installUpgradeUI() {
    const manager = document.querySelector('.playlist-manager');
    if (!manager || document.getElementById('playlist-upgrade-actions')) return;

    const box = document.createElement('div');
    box.className = 'playlist-actions';
    box.id = 'playlist-upgrade-actions';

    box.innerHTML = `
      <button id="btn-rename-playlist" type="button">Rename</button>
      <button id="btn-export-playlists" type="button">Export</button>
      <button id="btn-import-playlists" type="button">Import</button>
      <button id="btn-liked-playlist" type="button">Liked</button>
      <input id="playlist-import-file" type="file" accept="application/json" class="hidden">
    `;

    manager.appendChild(box);

    document.getElementById('btn-rename-playlist').addEventListener('click', renameActivePlaylist);
    document.getElementById('btn-export-playlists').addEventListener('click', exportPlaylists);
    document.getElementById('btn-import-playlists').addEventListener('click', () => {
      document.getElementById('playlist-import-file').click();
    });
    document.getElementById('playlist-import-file').addEventListener('change', importPlaylists);
    document.getElementById('btn-liked-playlist').addEventListener('click', createLikedPlaylist);
  }

  async function renameActivePlaylist() {
    const p = playlists.find(x => x.id === activePlaylistId);
    if (!p) return;

    const name = prompt('Nytt namn på spellistan:', p.name);
    if (!name || !name.trim()) return;

    p.name = name.trim();
    await playlistStorePut(p);
    renderPlaylistTabs();
    showToast('Spellista omdöpt!', 'success');
  }

  async function createLikedPlaylist() {
    let p = playlists.find(x => x.name.toLowerCase() === 'liked songs');

    if (!p) {
      p = await dbAddPlaylist({
        name: 'Liked songs',
        createdAt: Date.now()
      });
      playlists.push(p);
    }

    activePlaylistId = p.id;
    localStorage.setItem('runspace-active-playlist', String(activePlaylistId));
    await loadActivePlaylist();
    showToast('Liked songs öppnad', 'success');
  }

  async function exportPlaylists() {
    const allTracks = await dbGetAll();

    const data = {
      app: 'RunSpace Music',
      version: 1,
      exportedAt: new Date().toISOString(),
      playlists,
      tracks: allTracks.filter(t => t.type !== 'local')
    };

    const blob = new Blob([JSON.stringify(data, null, 2)], {
      type: 'application/json'
    });

    const a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = 'runspace-music-playlists.json';
    a.click();

    setTimeout(() => URL.revokeObjectURL(a.href), 1000);
    showToast('Spellistor exporterade!', 'success');
  }

  async function importPlaylists(e) {
    const file = e.target.files[0];
    e.target.value = '';

    if (!file) return;

    try {
      const text = await file.text();
      const data = JSON.parse(text);

      if (!Array.isArray(data.playlists) || !Array.isArray(data.tracks)) {
        showToast('Ogiltig importfil', 'error');
        return;
      }

      if (!confirm('Importera spellistor? Detta lägger till dem i din lista.')) return;

      const idMap = new Map();

      for (const oldPlaylist of data.playlists) {
        const newPlaylist = await dbAddPlaylist({
          name: oldPlaylist.name || 'Imported playlist',
          createdAt: Date.now()
        });

        playlists.push(newPlaylist);
        idMap.set(oldPlaylist.id, newPlaylist.id);
      }

      for (const oldTrack of data.tracks) {
        const playlistId = idMap.get(oldTrack.playlistId);
        if (!playlistId) continue;

        const cleanTrack = {
          ...oldTrack,
          playlistId
        };

        delete cleanTrack.id;
        delete cleanTrack.blobUrl;

        await dbAdd(cleanTrack);
      }

      activePlaylistId = playlists[playlists.length - 1].id;
      localStorage.setItem('runspace-active-playlist', String(activePlaylistId));

      await loadActivePlaylist();
      showToast('Import klar!', 'success');
    } catch (err) {
      console.error(err);
      showToast('Kunde inte importera filen', 'error');
    }
  }

  function patchLoaderWithSorting() {
    window.loadActivePlaylist = loadActivePlaylist = async function() {
      const allTracks = await dbGetAll();

      tracks = allTracks
        .filter(t => {
          if (t.type === 'local') return false;
          return t.playlistId === activePlaylistId;
        })
        .sort((a, b) => {
          const ao = typeof a.order === 'number' ? a.order : 999999;
          const bo = typeof b.order === 'number' ? b.order : 999999;
          return ao - bo;
        });

      currentIdx = -1;
      stopAll();
      renderPlaylistTabs();
      renderPlaylist();
      resetProgress();
    };
  }

  function patchPlaylistRendering() {
    window.renderPlaylist = renderPlaylist = function() {
      const el = document.getElementById('playlist');
      const empty = document.getElementById('playlist-empty');

      el.innerHTML = '';
      el.appendChild(empty);
      empty.style.display = tracks.length === 0 ? 'flex' : 'none';

      tracks.forEach((t, i) => {
        const div = document.createElement('div');
        div.className = 'track-item' + (i === currentIdx ? ' active' : '');
        div.dataset.idx = i;
        div.draggable = true;

        let badge = '';
        let thumb = '🎵';

        if (t.type === 'youtube') {
          badge = '<span class="type-badge">YT</span>';
          thumb = t.thumb ? `<img src="${t.thumb}" alt="">` : '▶';
        } else if (t.type === 'spotify') {
          badge = '<span class="type-badge">SP</span>';
          thumb = '🎧';
        } else {
          badge = '<span class="type-badge">LOC</span>';
          thumb = '🎵';
        }

        div.innerHTML = `
          <div class="track-thumb">${thumb}</div>
          <div class="track-info">
            <div class="track-name">${escapeHtml(t.title || 'Okänd låt')}</div>
            <div class="track-meta">${badge} ${t.type === 'youtube' ? 'YouTube' : t.type === 'spotify' ? 'Spotify' : 'Lokal fil'}</div>
          </div>
          <button class="track-remove" data-id="${t.id}" title="Ta bort">×</button>
        `;

        div.addEventListener('click', e => {
          if (e.target.closest('.track-remove')) return;
          playTrack(i);
        });

        div.addEventListener('dragstart', e => {
          div.classList.add('dragging');
          e.dataTransfer.setData('text/plain', String(i));
        });

        div.addEventListener('dragend', () => {
          div.classList.remove('dragging');
          document.querySelectorAll('.drag-over').forEach(x => x.classList.remove('drag-over'));
        });

        div.addEventListener('dragover', e => {
          e.preventDefault();
          div.classList.add('drag-over');
        });

        div.addEventListener('dragleave', () => {
          div.classList.remove('drag-over');
        });

        div.addEventListener('drop', async e => {
          e.preventDefault();
          div.classList.remove('drag-over');

          const from = Number(e.dataTransfer.getData('text/plain'));
          const to = Number(div.dataset.idx);

          if (!Number.isInteger(from) || !Number.isInteger(to) || from === to) return;

          const moved = tracks.splice(from, 1)[0];
          tracks.splice(to, 0, moved);

          tracks.forEach((track, idx) => {
            track.order = idx;
            if (track.type !== 'local') dbPut(track).catch(() => {});
          });

          if (currentIdx === from) currentIdx = to;
          else if (from < currentIdx && to >= currentIdx) currentIdx--;
          else if (from > currentIdx && to <= currentIdx) currentIdx++;

          renderPlaylist();
          showToast('Ordning sparad', 'success');
        });

        div.querySelector('.track-remove').addEventListener('click', async e => {
          e.stopPropagation();

          const id = e.currentTarget.dataset.id;
          const removedIdx = tracks.findIndex(t => String(t.id) === id);
          if (removedIdx === -1) return;

          const removedTrack = tracks[removedIdx];

          if (removedTrack.type !== 'local') {
            await dbDelete(Number(id)).catch(() => {});
          }

          tracks.splice(removedIdx, 1);

          tracks.forEach((track, idx) => {
            track.order = idx;
            if (track.type !== 'local') dbPut(track).catch(() => {});
          });

          if (currentIdx === removedIdx) {
            stopAll();
            currentIdx = -1;
          } else if (currentIdx > removedIdx) {
            currentIdx--;
          }

          renderPlaylist();
        });

        el.appendChild(div);
      });
    };
  }

  waitForApp();
})();
</script>

