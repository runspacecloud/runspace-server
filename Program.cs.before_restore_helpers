builder.Services
    .AddAuthentication(CookieAuthenticationDefaults.AuthenticationScheme)
    .AddCookie(options =>
    {
        options.Cookie.Name = "__Host-runspace_auth";
        options.Cookie.HttpOnly = true;
        options.Cookie.SameSite = SameSiteMode.Strict;
        options.Cookie.SecurePolicy = CookieSecurePolicy.Always;
        options.Cookie.Path = "/";
        options.ExpireTimeSpan = TimeSpan.FromDays(7);
        options.SlidingExpiration = true;

        options.Events = new CookieAuthenticationEvents
        {
            OnRedirectToLogin = ctx => { ctx.Response.StatusCode = 401; return Task.CompletedTask; },
            OnRedirectToAccessDenied = ctx => { ctx.Response.StatusCode = 403; return Task.CompletedTask; },
            OnValidatePrincipal = async ctx =>
            {
                var sessionMgr = ctx.HttpContext.RequestServices.GetRequiredService<SessionManager>();
                var killSwitch = ctx.HttpContext.RequestServices.GetRequiredService<EmergencyKillSwitch>();
                var username = ctx.Principal?.Identity?.Name?.Trim().ToLowerInvariant();
                var sessionId = ctx.Properties.GetString("SessionId");

                if (killSwitch.IsActive) { ctx.RejectPrincipal(); await ctx.HttpContext.SignOutAsync(); return; }
                if (string.IsNullOrWhiteSpace(username) || string.IsNullOrWhiteSpace(sessionId) || !sessionMgr.IsSessionValid(username, sessionId))
                { ctx.RejectPrincipal(); await ctx.HttpContext.SignOutAsync(); return; }

                var currentIp = ctx.HttpContext.Connection.RemoteIpAddress?.ToString() ?? "";
                var currentUa = ctx.HttpContext.Request.Headers.UserAgent.ToString();
                var sessionInfo = sessionMgr.GetSessionInfo(username, sessionId);
                if (sessionInfo != null)
                {
                    if (sessionInfo.LastActivity < DateTime.UtcNow.AddHours(-2))
                    { ctx.RejectPrincipal(); sessionMgr.InvalidateSpecificSession(username, sessionId); await ctx.HttpContext.SignOutAsync(); return; }

                    var maxAge = AppHelpers.IsAdmin(username) ? TimeSpan.FromHours(2) : TimeSpan.FromDays(7);
                    if (sessionInfo.CreatedAt < DateTime.UtcNow - maxAge)
                    { ctx.RejectPrincipal(); sessionMgr.InvalidateSpecificSession(username, sessionId); await ctx.HttpContext.SignOutAsync(); return; }

                    var anomaly = ctx.HttpContext.RequestServices.GetRequiredService<SessionAnomalyDetector>();
                    if (anomaly.AnalyzeSession(sessionInfo, currentIp, currentUa) >= 85)
                    {
                        var audit = ctx.HttpContext.RequestServices.GetRequiredService<SecurityAuditLogger>();
                        audit.LogSuspiciousActivity(currentIp, "session_anomaly", $"User {username}, origIp={sessionInfo.Ip}, newIp={currentIp}");
                        ctx.RejectPrincipal(); sessionMgr.InvalidateSpecificSession(username, sessionId); await ctx.HttpContext.SignOutAsync(); return;
                    }
                    sessionMgr.TouchSession(username, sessionId, currentIp);
                }
            }
        };
    });

builder.Services.AddAuthorization();
builder.Services.AddCors(options =>
{
    options.AddDefaultPolicy(policy =>
