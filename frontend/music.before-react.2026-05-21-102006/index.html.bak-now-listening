<script type="text/javascript" id="www-widgetapi-script" src="https://www.youtube.com/s/player/8456c9de/www-widgetapi.vflset/www-widgetapi.js" async=""></script><script>
const DB_NAME = 'runspace-music';
const DB_VER = 2;
const STORE = 'tracks';
const PLAYLIST_STORE = 'playlists';

let playlists = [];
let activePlaylistId = null;

let db;
let tracks = [];
let currentIdx = -1;
let isPlaying = false;
let shuffle = false;
let repeat = false;
let currentType = null;
let audioCtx, analyser, sourceNode, animFrame;

function openDB() {
  return new Promise((res, rej) => {
    const req = indexedDB.open(DB_NAME, DB_VER);
    req.onupgradeneeded = e => {
      const database = e.target.result;
      if (!database.objectStoreNames.contains(STORE)) {
        database.createObjectStore(STORE, { keyPath: 'id', autoIncrement: true });
      }

      if (!database.objectStoreNames.contains(PLAYLIST_STORE)) {
        database.createObjectStore(PLAYLIST_STORE, { keyPath: 'id', autoIncrement: true });
      }
    };
    req.onsuccess = e => { db = e.target.result; res(db); };
    req.onerror = () => rej(req.error);
  });
}

function dbGetAll() {
  return new Promise((res, rej) => {
    const tx = db.transaction(STORE, 'readonly');
    const req = tx.objectStore(STORE).getAll();
    req.onsuccess = () => res(req.result);
    req.onerror = () => rej(req.error);
  });
}

function dbAdd(track) {
  return new Promise((res, rej) => {
    const tx = db.transaction(STORE, 'readwrite');
    const req = tx.objectStore(STORE).add(track);
    req.onsuccess = () => { track.id = req.result; res(track); };
    req.onerror = () => rej(req.error);
  });
}

function dbDelete(id) {
  return new Promise((res, rej) => {
    const tx = db.transaction(STORE, 'readwrite');
    tx.objectStore(STORE).delete(id);
    tx.oncomplete = () => res();
    tx.onerror = () => rej(tx.error);
  });
}

function dbPut(track) {
  return new Promise((res, rej) => {
    const tx = db.transaction(STORE, 'readwrite');
    tx.objectStore(STORE).put(track);
    tx.oncomplete = () => res();
    tx.onerror = () => rej(tx.error);
  });
}

function dbClear() {
  return new Promise((res, rej) => {
    const tx = db.transaction(STORE, 'readwrite');
    tx.objectStore(STORE).clear();
    tx.oncomplete = () => res();
    tx.onerror = () => rej(tx.error);
  });
}

function dbGetAllPlaylists() {
  return new Promise((res, rej) => {
    const tx = db.transaction(PLAYLIST_STORE, 'readonly');
    const req = tx.objectStore(PLAYLIST_STORE).getAll();
    req.onsuccess = () => res(req.result);
    req.onerror = () => rej(req.error);
  });
}

function dbAddPlaylist(playlist) {
  return new Promise((res, rej) => {
    const tx = db.transaction(PLAYLIST_STORE, 'readwrite');
    const req = tx.objectStore(PLAYLIST_STORE).add(playlist);
    req.onsuccess = () => {
      playlist.id = req.result;
      res(playlist);
    };
    req.onerror = () => rej(req.error);
  });
}

function dbDeletePlaylist(id) {
  return new Promise((res, rej) => {
    const tx = db.transaction([PLAYLIST_STORE, STORE], 'readwrite');
    tx.objectStore(PLAYLIST_STORE).delete(id);

    const trackStore = tx.objectStore(STORE);
    const req = trackStore.getAll();

    req.onsuccess = () => {
      req.result
        .filter(t => t.playlistId === id)
        .forEach(t => trackStore.delete(t.id));
    };

    tx.oncomplete = () => res();
    tx.onerror = () => rej(tx.error);
  });
}

function renderPlaylistTabs() {
  const el = document.getElementById('playlist-tabs');
  if (!el) return;

  el.innerHTML = '';

  playlists.forEach(p => {
    const div = document.createElement('div');
    div.className = 'playlist-tab' + (p.id === activePlaylistId ? ' active' : '');

    div.innerHTML = `
      <div class="playlist-tab-name">${escapeHtml(p.name)}</div>
      <button class="playlist-tab-remove" title="Ta bort spellista">×</button>
    `;

    div.querySelector('.playlist-tab-name').addEventListener('click', async () => {
      activePlaylistId = p.id;
      localStorage.setItem('runspace-active-playlist', String(activePlaylistId));
      await loadActivePlaylist();
    });

    div.querySelector('.playlist-tab-remove').addEventListener('click', async e => {
      e.stopPropagation();

      if (playlists.length <= 1) {
        showToast('Du måste ha minst en spellista', 'error');
        return;
      }

      if (!confirm(`Ta bort spellistan "${p.name}"?`)) return;

      await dbDeletePlaylist(p.id);
      playlists = playlists.filter(x => x.id !== p.id);

      if (activePlaylistId === p.id) {
        activePlaylistId = playlists[0].id;
        localStorage.setItem('runspace-active-playlist', String(activePlaylistId));
      }

      await loadActivePlaylist();
      showToast('Spellista borttagen');
    });

    el.appendChild(div);
  });
}

async function loadActivePlaylist() {
  const allTracks = await dbGetAll();

  tracks = allTracks.filter(t => {
    if (t.type === 'local') return false;
    return t.playlistId === activePlaylistId;
  });

  currentIdx = -1;
  stopAll();
  renderPlaylistTabs();
  renderPlaylist();
  resetProgress();
}

function parseYouTubeId(url) {
  const patterns = [
    /youtube\.com\/watch\?.*v=([a-zA-Z0-9_-]{11})/,
    /youtu\.be\/([a-zA-Z0-9_-]{11})/,
    /youtube\.com\/embed\/([a-zA-Z0-9_-]{11})/,
    /youtube\.com\/shorts\/([a-zA-Z0-9_-]{11})/
  ];
  for (const p of patterns) {
    const m = url.match(p);
    if (m) return m[1];
  }
  return null;
}

function parseSpotifyEmbed(url) {
  const m = url.match(/spotify\.com\/(track|album|playlist|episode)\/([a-zA-Z0-9]+)/);
  if (!m) return null;
  return `https://open.spotify.com/embed/${m[1]}/${m[2]}?utm_source=generator&theme=0`;
}

function showToast(msg, type = '') {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.className = 'toast show' + (type ? ' ' + type : '');
  setTimeout(() => t.className = 'toast', 2500);
}

function renderPlaylist() {
  const el = document.getElementById('playlist');
  const empty = document.getElementById('playlist-empty');
  el.innerHTML = '';
  el.appendChild(empty);
  empty.style.display = tracks.length === 0 ? 'flex' : 'none';

  tracks.forEach((t, i) => {
    const div = document.createElement('div');
    div.className = 'track-item' + (i === currentIdx ? ' active' : '');
    div.dataset.idx = i;

    let badge = '';
    let thumb = '🎵';

    if (t.type === 'youtube') {
      badge = '<span class="type-badge">YT</span>';
      thumb = t.thumb ? `<img src="${t.thumb}" alt="">` : '▶';
    } else if (t.type === 'spotify') {
      badge = '<span class="type-badge">SP</span>';
      thumb = '🎧';
    } else {
      badge = '<span class="type-badge">LOC</span>';
      thumb = '🎵';
    }

    div.innerHTML = `
      <div class="track-thumb">${thumb}</div>
      <div class="track-info">
        <div class="track-name">${escapeHtml(t.title || 'Okänd låt')}</div>
        <div class="track-meta">${badge} ${t.type === 'youtube' ? 'YouTube' : t.type === 'spotify' ? 'Spotify' : 'Lokal fil'}</div>
      </div>
      <button class="track-remove" data-id="${t.id}" title="Ta bort">×</button>
    `;

    div.addEventListener('click', e => {
      if (e.target.closest('.track-remove')) return;
      playTrack(i);
    });

    div.querySelector('.track-remove').addEventListener('click', async e => {
      e.stopPropagation();
      const id = e.currentTarget.dataset.id;
      const removedIdx = tracks.findIndex(t => String(t.id) === id);
      if (removedIdx === -1) return;
      const removedTrack = tracks[removedIdx];

      if (removedTrack.type !== 'local') {
        await dbDelete(Number(id)).catch(() => {});
      }

      tracks.splice(removedIdx, 1);

      if (currentIdx === removedIdx) {
        stopAll();
        currentIdx = -1;
      } else if (currentIdx > removedIdx) {
        currentIdx--;
      }

      renderPlaylist();
    });

    el.appendChild(div);
  });
}

function escapeHtml(str) {
  return String(str).replace(/[&<>"']/g, s => ({
    '&': '&amp;',
    '<': '&lt;',
    '>': '&gt;',
    '"': '&quot;',
    "'": '&#039;'
  }[s]));
}

function updateBar(title, sub, thumb) {
  document.getElementById('now-title').textContent = title || 'Inget spelas';
  document.getElementById('now-sub').textContent = sub || '—';
  document.getElementById('now-thumb').innerHTML = thumb || '🎵';
}

function stopAll() {
  stopYTProgress();

  if (ytPlayer) {
    try { ytPlayer.stopVideo(); } catch(e) {}
  }

  document.getElementById('yt-art-container').classList.add('hidden');

  const audio = document.getElementById('audio-el');
  audio.pause();
  audio.src = '';

  document.getElementById('local-container').classList.add('hidden');
  document.getElementById('spotify-iframe').src = '';
  document.getElementById('spotify-container').classList.add('hidden');
  document.getElementById('idle-container').classList.remove('hidden');

  setPlaying(false);
  currentType = null;
  resetProgress();
}

function playTrack(idx) {
  if (idx < 0 || idx >= tracks.length) return;

  currentIdx = idx;
  const t = tracks[idx];

  renderPlaylist();
  stopAll();
  document.getElementById('idle-container').classList.add('hidden');

  if (t.type === 'youtube') playYouTube(t);
  else if (t.type === 'spotify') playSpotify(t);
  else playLocal(t);

  updateBar(
    t.title,
    t.type === 'youtube' ? 'YouTube' : t.type === 'spotify' ? 'Spotify' : 'Lokal fil',
    t.thumb ? `<img src="${t.thumb}" alt="">` : '🎵'
  );
}

let ytPlayer = null;
let ytReady = false;
let pendingYtTrack = null;

window.onYouTubeIframeAPIReady = function() {
  ytReady = true;

  ytPlayer = new YT.Player('yt-iframe', {
    width: '1',
    height: '1',
    videoId: '',
    playerVars: { autoplay: 1, controls: 0, rel: 0, playsinline: 1 },
    events: {
      onReady: function() {
        if (pendingYtTrack) {
          _loadYTVideo(pendingYtTrack);
          pendingYtTrack = null;
        }
      },
      onStateChange: function(e) {
        if (e.data === YT.PlayerState.ENDED) {
          stopYTProgress();
          if (repeat) playTrack(currentIdx);
          else playNext();
        }
        if (e.data === YT.PlayerState.PLAYING) {
          setPlaying(true);
          startYTProgress();
        }
        if (e.data === YT.PlayerState.PAUSED) {
          setPlaying(false);
        }
      },
      onError: function() {
        showToast('YouTube-fel, hoppar till nästa', 'error');
        playNext();
      }
    }
  });
};

function _loadYTVideo(t) {
  if (!ytPlayer) return;
  const vol = parseInt(document.getElementById('vol-slider').value, 10);
  ytPlayer.setVolume(vol);
  ytPlayer.loadVideoById(t.videoId);
}

function playYouTube(t) {
  const artContainer = document.getElementById('yt-art-container');
  artContainer.classList.remove('hidden');

  const thumbWrap = document.getElementById('yt-thumb-wrap');
  thumbWrap.innerHTML = t.thumb ? `<img src="${t.thumb}" alt="">` : `<div class="yt-thumb-placeholder">🎵</div>`;
  document.getElementById('yt-art-title').textContent = t.title;

  if (ytReady && ytPlayer) _loadYTVideo(t);
  else pendingYtTrack = t;

  currentType = 'youtube';
  document.getElementById('progress-row').style.opacity = '0.4';
}

function playSpotify(t) {
  const container = document.getElementById('spotify-container');
  const iframe = document.getElementById('spotify-iframe');
  container.classList.remove('hidden');
  iframe.src = t.embedUrl;
  currentType = 'spotify';
  setPlaying(false);
  document.getElementById('progress-row').style.opacity = '0.4';
}

function playLocal(t) {
  const container = document.getElementById('local-container');
  container.classList.remove('hidden');

  document.getElementById('local-title').textContent = t.title;
  document.getElementById('local-subtitle').textContent = t.artist || 'Okänd artist';

  const audio = document.getElementById('audio-el');
  audio.src = t.blobUrl;
  audio.volume = document.getElementById('vol-slider').value / 100;

  audio.play().then(() => {
    setPlaying(true);
    currentType = 'local';
    setupVisualizer(audio);
    document.getElementById('progress-row').style.opacity = '1';
  }).catch(() => showToast('Kunde inte spela filen', 'error'));
}

function setPlaying(val) {
  isPlaying = val;
  document.getElementById('play-icon').style.display = val ? 'none' : 'inline';
  document.getElementById('pause-icon').style.display = val ? 'inline' : 'none';
}

function togglePlay() {
  if (currentIdx < 0) return;

  const t = tracks[currentIdx];

  if (t.type === 'youtube') {
    if (!ytPlayer) return;
    if (isPlaying) {
      ytPlayer.pauseVideo();
      setPlaying(false);
    } else {
      ytPlayer.playVideo();
      setPlaying(true);
    }
  } else if (t.type === 'local') {
    const audio = document.getElementById('audio-el');
    if (isPlaying) {
      audio.pause();
      setPlaying(false);
    } else {
      audio.play();
      setPlaying(true);
    }
  }
}

function playNext() {
  if (tracks.length === 0) return;

  let next;

  if (shuffle && tracks.length > 1) {
    do {
      next = Math.floor(Math.random() * tracks.length);
    } while (next === currentIdx);
  } else {
    next = (currentIdx + 1) % tracks.length;
  }

  playTrack(next);
}

function playPrev() {
  if (tracks.length === 0) return;
  const prev = (currentIdx - 1 + tracks.length) % tracks.length;
  playTrack(prev);
}

function resetProgress() {
  document.getElementById('progress-fill').style.width = '0%';
  document.getElementById('time-current').textContent = '0:00';
  document.getElementById('time-total').textContent = '0:00';
  document.getElementById('progress-row').style.opacity = '0.4';
}

function fmtTime(s) {
  if (!isFinite(s) || isNaN(s)) return '0:00';
  const m = Math.floor(s / 60);
  const sec = Math.floor(s % 60).toString().padStart(2, '0');
  return `${m}:${sec}`;
}

const audio = document.getElementById('audio-el');

audio.addEventListener('timeupdate', () => {
  if (currentType !== 'local') return;

  const pct = audio.duration ? (audio.currentTime / audio.duration) * 100 : 0;
  document.getElementById('progress-fill').style.width = pct + '%';
  document.getElementById('time-current').textContent = fmtTime(audio.currentTime);
  document.getElementById('time-total').textContent = fmtTime(audio.duration);
});

audio.addEventListener('ended', () => {
  if (repeat) playTrack(currentIdx);
  else playNext();
});

document.getElementById('progress-bar').addEventListener('click', e => {
  const rect = e.currentTarget.getBoundingClientRect();
  const pct = (e.clientX - rect.left) / rect.width;

  if (currentType === 'local') {
    audio.currentTime = pct * audio.duration;
  } else if (currentType === 'youtube' && ytPlayer) {
    try { ytPlayer.seekTo(pct * ytPlayer.getDuration(), true); } catch(e) {}
  }
});

let ytProgressInterval = null;

function startYTProgress() {
  if (ytProgressInterval) clearInterval(ytProgressInterval);

  ytProgressInterval = setInterval(() => {
    if (currentType !== 'youtube' || !ytPlayer) return;

    try {
      const cur = ytPlayer.getCurrentTime();
      const dur = ytPlayer.getDuration();

      if (!dur) return;

      document.getElementById('progress-fill').style.width = (cur / dur * 100) + '%';
      document.getElementById('time-current').textContent = fmtTime(cur);
      document.getElementById('time-total').textContent = fmtTime(dur);
      document.getElementById('progress-row').style.opacity = '1';
    } catch(e) {}
  }, 500);
}

function stopYTProgress() {
  if (ytProgressInterval) {
    clearInterval(ytProgressInterval);
    ytProgressInterval = null;
  }
}

let audioCtxSetup = false;

function setupVisualizer(audioEl) {
  if (animFrame) cancelAnimationFrame(animFrame);

  if (!audioCtx || audioCtx.state === 'closed') {
    audioCtx = new (window.AudioContext || window.webkitAudioContext)();
    audioCtxSetup = false;
  }

  if (audioCtx.state === 'suspended') {
    audioCtx.resume().catch(() => {});
  }

  if (!audioCtxSetup) {
    analyser = audioCtx.createAnalyser();
    analyser.fftSize = 64;
    sourceNode = audioCtx.createMediaElementSource(audioEl);
    sourceNode.connect(analyser);
    analyser.connect(audioCtx.destination);
    audioCtxSetup = true;
  }

  const canvas = document.getElementById('visualizer');
  const ctx = canvas.getContext('2d');
  const buf = new Uint8Array(analyser.frequencyBinCount);

  function draw() {
    animFrame = requestAnimationFrame(draw);
    analyser.getByteFrequencyData(buf);
    ctx.clearRect(0, 0, canvas.width, canvas.height);

    const barW = canvas.width / buf.length;

    buf.forEach((v, i) => {
      const h = (v / 255) * canvas.height;
      const alpha = 0.4 + (v / 255) * 0.6;
      ctx.fillStyle = `rgba(88,101,242,${alpha})`;
      ctx.fillRect(i * barW, canvas.height - h, barW - 1, h);
    });
  }

  draw();
}

async function addUrl() {
  const input = document.getElementById('url-input');
  const url = input.value.trim();

  if (!url) return;

  const ytId = parseYouTubeId(url);

  if (ytId) {
    const thumb = `https://i.ytimg.com/vi/${ytId}/mqdefault.jpg`;
    const track = {
      type: 'youtube',
      playlistId: activePlaylistId,
      videoId: ytId,
      title: 'YouTube – ' + ytId,
      thumb,
      blobUrl: null,
      embedUrl: null
    };

    const saved = await dbAdd(track);
    tracks.push(saved);
    renderPlaylist();
    showToast('YouTube-låt tillagd!', 'success');
    input.value = '';

    fetch(`https://www.youtube.com/oembed?url=https://www.youtube.com/watch?v=${ytId}&format=json`)
      .then(r => r.json())
      .then(async data => {
        saved.title = data.title;
        await dbPut(saved).catch(() => {});
        renderPlaylist();

        if (currentIdx >= 0 && tracks[currentIdx] && tracks[currentIdx].id === saved.id) {
          document.getElementById('now-title').textContent = data.title;
          document.getElementById('yt-art-title').textContent = data.title;
        }
      })
      .catch(() => {});

    return;
  }

  const spEmbed = parseSpotifyEmbed(url);

  if (spEmbed) {
    const track = {
      type: 'spotify',
      playlistId: activePlaylistId,
      embedUrl: spEmbed,
      title: 'Spotify – ' + url.split('/').pop().split('?')[0],
      thumb: null,
      blobUrl: null,
      videoId: null
    };

    const saved = await dbAdd(track);
    tracks.push(saved);
    renderPlaylist();
    showToast('Spotify-låt tillagd!', 'success');
    input.value = '';
    return;
  }

  showToast('Kunde inte känna igen URL:en. Stöder YouTube och Spotify.', 'error');
}

document.getElementById('file-input').addEventListener('change', async e => {
  const files = Array.from(e.target.files);

  for (const file of files) {
    const blobUrl = URL.createObjectURL(file);
    const name = file.name.replace(/\.[^/.]+$/, '');

    const track = {
      type: 'local',
      playlistId: activePlaylistId,
      title: name,
      artist: '',
      blobUrl,
      thumb: null,
      videoId: null,
      embedUrl: null,
      id: Date.now() + Math.random()
    };

    tracks.push(track);
  }

  renderPlaylist();
  showToast(`${files.length} fil(er) tillagda!`, 'success');
  e.target.value = '';
});

document.getElementById('btn-add-url').addEventListener('click', addUrl);
document.getElementById('url-input').addEventListener('keydown', e => {
  if (e.key === 'Enter') addUrl();
});
document.getElementById('btn-play').addEventListener('click', togglePlay);
document.getElementById('btn-next').addEventListener('click', playNext);
document.getElementById('btn-prev').addEventListener('click', playPrev);

document.getElementById('btn-shuffle').addEventListener('click', function() {
  shuffle = !shuffle;
  this.classList.toggle('active', shuffle);
});

document.getElementById('btn-repeat').addEventListener('click', function() {
  repeat = !repeat;
  this.classList.toggle('active', repeat);
});

document.getElementById('vol-slider').addEventListener('input', e => {
  const vol = e.target.value / 100;
  audio.volume = vol;

  if (ytPlayer) {
    try { ytPlayer.setVolume(e.target.value); } catch(err) {}
  }
});


document.getElementById('btn-create-playlist').addEventListener('click', async () => {
  const input = document.getElementById('playlist-name-input');
  const name = input.value.trim();

  if (!name) {
    showToast('Skriv ett namn på spellistan', 'error');
    return;
  }

  const playlist = await dbAddPlaylist({
    name,
    createdAt: Date.now()
  });

  playlists.push(playlist);
  activePlaylistId = playlist.id;
  localStorage.setItem('runspace-active-playlist', String(activePlaylistId));

  input.value = '';
  await loadActivePlaylist();

  showToast('Spellista skapad!', 'success');
});

document.getElementById('playlist-name-input').addEventListener('keydown', e => {
  if (e.key === 'Enter') {
    document.getElementById('btn-create-playlist').click();
  }
});


document.getElementById('btn-clear-all').addEventListener('click', async () => {
  if (!confirm('Rensa denna spellista?')) return;

  const currentTracks = tracks.slice();

  for (const t of currentTracks) {
    if (t.id && t.type !== 'local') {
      await dbDelete(t.id).catch(() => {});
    }
  }

  tracks = [];
  currentIdx = -1;
  stopAll();
  renderPlaylist();
  showToast('Spellistan rensad');
});

async function init() {
  try {
    await openDB();

    playlists = await dbGetAllPlaylists();

    if (playlists.length === 0) {
      const first = await dbAddPlaylist({
        name: 'Main playlist',
        createdAt: Date.now()
      });

      playlists = [first];
      activePlaylistId = first.id;
      localStorage.setItem('runspace-active-playlist', String(activePlaylistId));
    } else {
      const savedActive = Number(localStorage.getItem('runspace-active-playlist'));
      activePlaylistId = playlists.some(p => p.id === savedActive)
        ? savedActive
        : playlists[0].id;
    }

    const saved = await dbGetAll();

    for (const t of saved) {
      if (!t.playlistId) {
        t.playlistId = activePlaylistId;
        await dbPut(t).catch(() => {});
      }

      if (t.type === 'local') {
        await dbDelete(t.id).catch(() => {});
      }
    }

    await loadActivePlaylist();
  } catch (err) {
    console.error(err);
    showToast('Kunde inte starta musikspelaren', 'error');
  }
}

init();
</script>

