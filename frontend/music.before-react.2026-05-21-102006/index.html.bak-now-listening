<html lang="sv"><head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="manifest" href="/manifest.webmanifest">
  <meta name="theme-color" content="#0a0f1a">
  <meta name="mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <title>RunSpace Music</title>

  <style>
    *{box-sizing:border-box;margin:0;padding:0}
    :root{--bg:#07070d;--surface:#0b1020;--surface2:#11182a;--surface3:#18213a;--border:rgba(255,255,255,.1);--text:#eaf0ff;--text2:#9fb0c8;--text3:#6f7f99;--accent:#5865f2;--danger:#ef4444;--success:#10b981}
    html,body{height:100%;background:var(--bg);color:var(--text);font-family:system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;overflow:hidden}
    body{display:flex;flex-direction:column}
    .hidden{display:none!important}
    button,input{font:inherit;color:inherit}
    button{cursor:pointer}

    .topbar{height:54px;flex:0 0 auto;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:10px;padding:0 18px;background:rgba(8,13,24,.96)}
    .topbar-logo{display:flex;align-items:center;gap:9px;font-weight:800;text-decoration:none;color:var(--text)}
    .topbar-logo svg{width:25px;height:25px}
    .topbar-sep,.topbar-title{color:var(--text2);font-weight:600}

    .layout{flex:1;min-height:0;display:grid;grid-template-columns:340px 1fr;background:radial-gradient(circle at 60% 35%,rgba(88,101,242,.13),transparent 38%),var(--bg)}
    .sidebar{border-right:1px solid var(--border);padding:16px;background:rgba(8,13,24,.9);overflow:auto}
    .sidebar-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px}
    .sidebar h2{font-size:16px;letter-spacing:-.02em}

    .input-row{display:flex;gap:8px;margin-bottom:10px}
    .url-input{flex:1;min-width:0;background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:10px 11px;outline:none}
    .url-input:focus{border-color:var(--accent);box-shadow:0 0 0 3px rgba(88,101,242,.18)}
    .btn-add,.btn-file,.btn-icon,.ctrl-btn,.track-remove{background:var(--surface2);border:1px solid var(--border);border-radius:10px;padding:9px 12px;color:var(--text)}
    .btn-add{background:var(--accent);border-color:var(--accent);color:white;font-weight:800}
    .btn-file{width:100%;display:flex;align-items:center;justify-content:center;gap:8px}
    .btn-icon{padding:8px}
    button:hover{border-color:rgba(255,255,255,.22)}
    #file-input{display:none}

    .playlist-manager{margin-bottom:14px;padding-bottom:14px;border-bottom:1px solid var(--border)}
    .playlist-tabs{display:flex;flex-direction:column;gap:7px;margin-top:8px}
    .playlist-tab{display:grid;grid-template-columns:1fr 34px;align-items:center;gap:8px;padding:8px 9px;border-radius:11px;background:var(--surface);border:1px solid transparent}
    .playlist-tab.active{border-color:var(--accent);background:#10182d}
    .playlist-tab-name{font-size:13px;font-weight:800;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;cursor:pointer}
    .playlist-tab-remove{background:transparent;border:1px solid var(--border);color:var(--text3);border-radius:8px;padding:5px}
    .playlist{display:flex;flex-direction:column;gap:8px;margin-top:12px}
    .playlist-empty{min-height:190px;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;color:var(--text3);gap:10px;border:1px dashed var(--border);border-radius:14px}
    .track-item{display:grid;grid-template-columns:56px 1fr 34px;gap:10px;align-items:center;padding:8px;border-radius:13px;background:var(--surface);border:1px solid transparent;cursor:pointer}
    .track-item:hover,.track-item.active{border-color:var(--accent);background:#10182d}
    .track-thumb{width:56px;height:42px;border-radius:9px;background:#050812;display:grid;place-items:center;overflow:hidden}
    .track-thumb img{width:100%;height:100%;object-fit:cover}
    .track-info{min-width:0}
    .track-name{font-size:13px;font-weight:750;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
    .track-meta{font-size:11px;color:var(--text3)}
    .type-badge{font-size:10px;font-weight:900;margin-right:5px;color:var(--accent)}
    .track-remove{padding:7px;border-radius:9px;color:var(--text3)}

    .main{display:flex;align-items:center;justify-content:center;min-width:0;overflow:hidden}
    .player-area{text-align:center;width:100%;max-width:680px;padding:30px}
    #idle-container{color:var(--text3)}
    .idle-icon{font-size:56px;margin-bottom:16px}
    .idle-text{font-size:16px;line-height:1.5}

    #yt-container{position:absolute;width:1px;height:1px;opacity:.01;pointer-events:none}
    .yt-thumb-wrap,.local-art{width:min(420px,80vw);height:240px;margin:0 auto 18px;border-radius:22px;background:linear-gradient(135deg,var(--surface2),var(--surface3));overflow:hidden;display:grid;place-items:center;box-shadow:0 25px 80px rgba(0,0,0,.35)}
    .yt-thumb-wrap img{width:100%;height:100%;object-fit:cover}
    .yt-title,.local-title{font-size:24px;font-weight:850;margin-bottom:8px}
    .yt-sub,.local-subtitle{color:var(--text3)}
    .yt-badge{color:var(--accent);font-weight:900}
    .spotify-embed{border-radius:18px;max-width:100%}
    canvas{margin-top:16px;max-width:100%}

    .player-bar{height:80px;flex:0 0 auto;border-top:1px solid var(--border);background:rgba(8,13,24,.98);display:grid;grid-template-columns:300px 1fr 220px;align-items:center;gap:20px;padding:0 18px}
    .now-playing{display:flex;align-items:center;gap:12px;min-width:0}
    .now-thumb{width:48px;height:48px;border-radius:11px;background:var(--surface2);display:grid;place-items:center;overflow:hidden;flex:0 0 auto}
    .now-thumb img{width:100%;height:100%;object-fit:cover}
    .now-info{min-width:0}
    .now-title{font-size:13px;font-weight:800;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
    .now-sub{font-size:12px;color:var(--text3)}

    .controls{display:flex;flex-direction:column;align-items:center;gap:8px;min-width:0}
    .ctrl-btns{display:flex;align-items:center;gap:8px}
    .ctrl-btn{width:36px;height:36px;padding:0;display:grid;place-items:center;border-radius:999px}
    .ctrl-btn.active{color:var(--accent);border-color:var(--accent)}
    .play-btn{width:44px;height:44px;background:var(--accent);border-color:var(--accent);color:white}

    .progress-row{width:100%;display:grid;grid-template-columns:44px 1fr 44px;align-items:center;gap:10px}
    .time-label{font-size:11px;color:var(--text3);font-variant-numeric:tabular-nums}
    .progress-bar{height:7px;background:var(--surface2);border-radius:999px;overflow:hidden;cursor:pointer}
    .progress-fill{height:100%;background:var(--accent);border-radius:999px}

    .volume-row{display:flex;align-items:center;gap:10px;justify-content:flex-end}
    .vol-slider{width:130px;accent-color:var(--accent)}

    .toast{position:fixed;left:50%;bottom:96px;transform:translateX(-50%) translateY(20px);background:#11182a;border:1px solid var(--border);color:var(--text);padding:10px 14px;border-radius:12px;opacity:0;pointer-events:none;transition:.2s;z-index:999}
    .toast.show{opacity:1;transform:translateX(-50%) translateY(0)}
    .toast.success{border-color:rgba(16,185,129,.35)}
    .toast.error{border-color:rgba(239,68,68,.35)}

    @media(max-width:800px){
      html,body{overflow:auto}
      .layout{grid-template-columns:1fr;min-height:calc(100vh - 134px)}
      .sidebar{border-right:0;border-bottom:1px solid var(--border);max-height:42vh}
      .player-bar{grid-template-columns:1fr;height:auto;padding:12px;gap:12px}
      .volume-row{justify-content:center}
    }
  
    .playlist-actions{display:grid;grid-template-columns:1fr 1fr;gap:7px;margin-top:8px}
    .playlist-actions button{background:var(--surface2);border:1px solid var(--border);border-radius:10px;padding:8px 9px;color:var(--text);font-size:12px;font-weight:800}
    .track-item.dragging{opacity:.45}
    .track-item.drag-over{border-color:var(--success);background:#10251f}

  </style>
</head>

