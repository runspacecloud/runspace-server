    { ctx.Response.StatusCode = 429; ctx.Response.Headers["Retry-After"] = "60"; await ctx.Response.WriteAsJsonAsync(new { message = "För många förfrågningar." }); return; }
    await next();
});

app.Use(async (ctx, next) =>
{
